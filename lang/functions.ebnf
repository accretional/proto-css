(* CSS Function definitions
   Generated / hand-authored from docs/syntax/functions.txt and docs/syntax/datatypes.txt.
   See docs/GUIDE_TO_EBNF_TRANSFORMATION.md for transformation rationale.

   Functions already defined here were originally in datatype.ebnf; moved here
   so datatypes.ebnf can reference them. Cross-file references are resolved at
   compile time by the gluon compiler.
*)


(* <contrast-color()> *)
contrast_color_fn = contrast_color , left_parenthesis_symbol , color_type , right_parenthesis_symbol ;

(* <sibling-count()> — takes no parameters; returns sibling count as integer *)
sibling_count_fn = sibling_count , left_parenthesis_symbol , right_parenthesis_symbol ;

(* <sibling-index()> — takes no parameters; returns element's 1-based sibling position *)
sibling_index_fn = sibling_index , left_parenthesis_symbol , right_parenthesis_symbol ;

(* <device-cmyk()> *)
device_cmyk_fn = legacy_device_cmyk_syntax_type | modern_device_cmyk_syntax_type ;

(* <color-mix()> *)
color_mix_fn = color_mix , left_parenthesis_symbol , [ color_interpolation_method_type ] , comma_symbol , color_mix_fn_item , { comma_symbol , color_mix_fn_item } , right_parenthesis_symbol ;

(* <rgb()> *)
rgb_fn = legacy_rgb_syntax_type | modern_rgb_syntax_type ;

(* <rgba()> *)
rgba_fn = legacy_rgba_syntax_type | modern_rgba_syntax_type ;

(* <hsl()> *)
hsl_fn = legacy_hsl_syntax_type | modern_hsl_syntax_type ;

(* <hsla()> *)
hsla_fn = legacy_hsla_syntax_type | modern_hsla_syntax_type ;

(* <hwb()> *)
hwb_fn = hwb , left_parenthesis_symbol , [ from , color_type ] , ( hue_type | none ) , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <lab()> *)
lab_fn = lab , left_parenthesis_symbol , [ from , color_type ] , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <lch()> *)
lch_fn = lch , left_parenthesis_symbol , [ from , color_type ] , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , ( hue_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <oklab()> *)
oklab_fn = oklab , left_parenthesis_symbol , [ from , color_type ] , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <oklch()> *)
oklch_fn = oklch , left_parenthesis_symbol , [ from , color_type ] , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , ( hue_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <ictcp()> *)
ictcp_fn = ictcp , left_parenthesis_symbol , [ from , color_type ] , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <jzazbz()> *)
jzazbz_fn = jzazbz , left_parenthesis_symbol , [ from , color_type ] , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <jzczhz()> *)
jzczhz_fn = jzczhz , left_parenthesis_symbol , [ from , color_type ] , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , ( hue_type | none ) , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <alpha()> *)
alpha_fn = alpha , left_parenthesis_symbol , from , color_type , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <color()> *)
color_fn = color , left_parenthesis_symbol , [ from , color_type ] , colorspace_params_type , [ solidus_symbol , ( alpha_value_type | none ) ] , right_parenthesis_symbol ;

(* <hdr-color()> *)
hdr_color_fn = color_hdr , left_parenthesis_symbol , hdr_color_fn_item , comma_symbol , hdr_color_fn_item , right_parenthesis_symbol ;

(* <superellipse()> *)
superellipse_fn = superellipse , left_parenthesis_symbol , ( number_type | infinity | _infinity ) , right_parenthesis_symbol ;

(* <linear()> *)
linear_fn = linear , left_parenthesis_symbol , linear_fn_item , { comma_symbol , linear_fn_item } , right_parenthesis_symbol ;

(* <cubic-bezier()> *)
cubic_bezier_fn = cubic_bezier , left_parenthesis_symbol , cubic_bezier_fn_item , comma_symbol , cubic_bezier_fn_item , right_parenthesis_symbol ;

(* <steps()> *)
steps_fn = steps , left_parenthesis_symbol , integer_type , comma_symbol , [ step_position_type ] , right_parenthesis_symbol ;

(* <blur()> *)
blur_fn = blur , left_parenthesis_symbol , [ length_type ] , right_parenthesis_symbol ;

(* <brightness()> *)
brightness_fn = brightness , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <contrast()> *)
contrast_fn = contrast , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <drop-shadow()> *)
drop_shadow_fn = drop_shadow , left_parenthesis_symbol , ( [ color_type ] , length_type , length_type , [ length_type ] ) , right_parenthesis_symbol ;

(* <grayscale()> *)
grayscale_fn = grayscale , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <hue-rotate()> *)
hue_rotate_fn = hue_rotate , left_parenthesis_symbol , [ ( angle_type | digit_0_symbol ) ] , right_parenthesis_symbol ;

(* <invert()> *)
invert_fn = invert , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <opacity()> *)
opacity_fn = opacity , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <sepia()> *)
sepia_fn = sepia , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <saturate()> *)
saturate_fn = saturate , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <linear-gradient()> *)
linear_gradient_fn = linear_gradient , left_parenthesis_symbol , linear_gradient_syntax_type , right_parenthesis_symbol ;

(* <repeating-linear-gradient()> *)
repeating_linear_gradient_fn = repeating_linear_gradient , left_parenthesis_symbol , linear_gradient_syntax_type , right_parenthesis_symbol ;

(* <radial-gradient()> *)
radial_gradient_fn = radial_gradient , left_parenthesis_symbol , radial_gradient_syntax_type , right_parenthesis_symbol ;

(* <repeating-radial-gradient()> *)
repeating_radial_gradient_fn = repeating_radial_gradient , left_parenthesis_symbol , radial_gradient_syntax_type , right_parenthesis_symbol ;

(* <conic-gradient()> *)
conic_gradient_fn = conic_gradient , left_parenthesis_symbol , conic_gradient_syntax_type , right_parenthesis_symbol ;

(* <repeating-conic-gradient()> *)
repeating_conic_gradient_fn = repeating_conic_gradient , left_parenthesis_symbol , conic_gradient_syntax_type , right_parenthesis_symbol ;

(* <image()> *)
image_fn = image , left_parenthesis_symbol , [ image_tags_type ] , (* ! at-least-one *) [ image_src_type ] , comma_symbol , [ color_type ] , right_parenthesis_symbol ;

(* <image-set()> *)
image_set_fn = image_set , left_parenthesis_symbol , image_set_option_type , { comma_symbol , image_set_option_type } , right_parenthesis_symbol ;

(* <cross-fade()> *)
cross_fade_fn = cross_fade , left_parenthesis_symbol , cf_image_type , { comma_symbol , cf_image_type } , right_parenthesis_symbol ;

(* <element()> *)
element_fn = element , left_parenthesis_symbol , id_selector_type , right_parenthesis_symbol ;

(* scale3d( [ <number> | <percentage> ]#{3} ) *)
scale3d_fn =
  scale3d , left_parenthesis_symbol ,
    ( number_type | percentage_type ) , comma_symbol ,
    ( number_type | percentage_type ) , comma_symbol ,
    ( number_type | percentage_type ) ,
  right_parenthesis_symbol ;

(* scale( <number> , <number>? ) *)
scale_fn = scale , left_parenthesis_symbol , number_type , [ comma_symbol , number_type ] , right_parenthesis_symbol ;

(* scaleX( <number> ) *)
scaleX_fn = scaleX , left_parenthesis_symbol , number_type , right_parenthesis_symbol ;

(* scaleY( <number> ) *)
scaleY_fn = scaleY , left_parenthesis_symbol , number_type , right_parenthesis_symbol ;

(* scaleZ( [ <number> | <percentage> ] ) *)
scaleZ_fn = scaleZ , left_parenthesis_symbol , ( number_type | percentage_type ) , right_parenthesis_symbol ;

(* translate3d( <length-percentage> , <length-percentage> , <length> ) *)
translate3d_fn =
  translate3d , left_parenthesis_symbol ,
    length_percentage_type , comma_symbol ,
    length_percentage_type , comma_symbol ,
    length_type ,
  right_parenthesis_symbol ;

(* translate( <length-percentage> , <length-percentage>? ) *)
translate_fn = translate , left_parenthesis_symbol , length_percentage_type , [ comma_symbol , length_percentage_type ] , right_parenthesis_symbol ;

(* translateX( <length-percentage> ) *)
translateX_fn = translateX , left_parenthesis_symbol , length_percentage_type , right_parenthesis_symbol ;

(* translateY( <length-percentage> ) *)
translateY_fn = translateY , left_parenthesis_symbol , length_percentage_type , right_parenthesis_symbol ;

(* translateZ( <length> ) *)
translateZ_fn = translateZ , left_parenthesis_symbol , length_type , right_parenthesis_symbol ;

(* rotate3d( <number> , <number> , <number> , [ <angle> | <0> ] ) *)
rotate3d_fn =
  rotate3d , left_parenthesis_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    ( angle_type | digit_0_symbol ) ,
  right_parenthesis_symbol ;

(* rotate( [ <angle> | <0> ] ) *)
rotate_fn = rotate , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* rotateX( [ <angle> | <0> ] ) *)
rotateX_fn = rotateX , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* rotateY( [ <angle> | <0> ] ) *)
rotateY_fn = rotateY , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* rotateZ( [ <angle> | <0> ] ) *)
rotateZ_fn = rotateZ , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* skew( [ <angle> | <0> ] , [ <angle> | <0> ]? ) *)
skew_fn = skew , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , [ comma_symbol , ( angle_type | digit_0_symbol ) ] , right_parenthesis_symbol ;

(* skewX( [ <angle> | <0> ] ) *)
skewX_fn = skewX , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* skewY( [ <angle> | <0> ] ) *)
skewY_fn = skewY , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* matrix3d( <number>#{16} ) — 4×4 homogeneous matrix, 16 comma-separated numbers *)
matrix3d_fn =
  matrix3d , left_parenthesis_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type ,
  right_parenthesis_symbol ;

(* matrix( <number>#{6} ) — 2D homogeneous matrix, 6 comma-separated numbers *)
matrix_fn =
  matrix , left_parenthesis_symbol ,
    number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type ,
  right_parenthesis_symbol ;

(* perspective( [ <length [0,∞]> | none ] ) *)
perspective_fn = perspective , left_parenthesis_symbol , ( length_type | none ) , right_parenthesis_symbol ;

(* inset( <length-percentage>{1,4} [ round <border-radius> ]? ) *)
inset_fn = inset , left_parenthesis_symbol ,
    length_percentage_type , [ length_percentage_type ] , [ length_percentage_type ] , [ length_percentage_type ] ,
    [ round , border_radius_type ] ,
  right_parenthesis_symbol ;

(* circle( <radial-size>? [ at <position> ]? ) *)
circle_fn = circle , left_parenthesis_symbol , [ radial_size_type ] , [ at , position_type ] , right_parenthesis_symbol ;

(* ellipse( <radial-size>? [ at <position> ]? ) *)
ellipse_fn = ellipse , left_parenthesis_symbol , [ radial_size_type ] , [ at , position_type ] , right_parenthesis_symbol ;

(* polygon( <fill-rule>? [ round <length> ]? , [ <length-percentage> <length-percentage> ]# ) *)
polygon_fn = polygon , left_parenthesis_symbol ,
    [ fill_rule_type ] , [ round , length_type ] , comma_symbol ,
    length_percentage_type , length_percentage_type , { comma_symbol , length_percentage_type , length_percentage_type } ,
  right_parenthesis_symbol ;

(* path( <fill-rule>? , <string> )  — comma only present when fill-rule given *)
path_fn = path , left_parenthesis_symbol , [ fill_rule_type , comma_symbol ] , string_type , right_parenthesis_symbol ;

(* rect( [ <length-percentage> | auto ]{4} [ round <border-radius> ]? ) *)
rect_fn = rect , left_parenthesis_symbol ,
    ( length_percentage_type | auto ) , ( length_percentage_type | auto ) ,
    ( length_percentage_type | auto ) , ( length_percentage_type | auto ) ,
    [ round , border_radius_type ] ,
  right_parenthesis_symbol ;

(* xywh( <length-percentage>{2} <length-percentage>{2} [ round <border-radius> ]? ) *)
xywh_fn = xywh , left_parenthesis_symbol ,
    length_percentage_type , length_percentage_type ,
    length_percentage_type , length_percentage_type ,
    [ round , border_radius_type ] ,
  right_parenthesis_symbol ;

(* ── shape() ─────────────────────────────────────────────────────────────── *)

(* shape( <fill-rule>? from <position> , <shape-command># ) *)
shape_fn = shape , left_parenthesis_symbol ,
    [ fill_rule_type ] , from , position_type , comma_symbol ,
    shape_command_type , { comma_symbol , shape_command_type } ,
  right_parenthesis_symbol ;


(* ── Math functions ─────────────────────────────────────────────────────── *)

(* abs( <calc-sum> ) *)
abs_fn = abs , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* acos( <calc-sum> ) *)
acos_fn = acos , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* asin( <calc-sum> ) *)
asin_fn = asin , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* atan( <calc-sum> ) *)
atan_fn = atan , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* atan2( <calc-sum> , <calc-sum> ) *)
atan2_fn = atan2 , left_parenthesis_symbol , calc_sum_type , comma_symbol , calc_sum_type , right_parenthesis_symbol ;

(* calc( <calc-sum> ) *)
calc_fn = calc , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* clamp( [ <calc-sum> | none ] , <calc-sum> , [ <calc-sum> | none ] ) *)
clamp_fn = clamp , left_parenthesis_symbol , ( calc_sum_type | none ) , comma_symbol , calc_sum_type , comma_symbol , ( calc_sum_type | none ) , right_parenthesis_symbol ;

(* cos( <calc-sum> ) *)
cos_fn = cos , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* exp( <calc-sum> ) *)
exp_fn = exp , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* hypot( <calc-sum># ) *)
hypot_fn = hypot , left_parenthesis_symbol , calc_sum_type , { comma_symbol , calc_sum_type } , right_parenthesis_symbol ;

(* log( <calc-sum> , <calc-sum>? ) *)
log_fn = log , left_parenthesis_symbol , calc_sum_type , [ comma_symbol , calc_sum_type ] , right_parenthesis_symbol ;

(* max( <calc-sum># ) *)
max_fn = max , left_parenthesis_symbol , calc_sum_type , { comma_symbol , calc_sum_type } , right_parenthesis_symbol ;

(* min( <calc-sum># ) *)
min_fn = min , left_parenthesis_symbol , calc_sum_type , { comma_symbol , calc_sum_type } , right_parenthesis_symbol ;

(* mod( <calc-sum> , <calc-sum> ) *)
mod_fn = mod , left_parenthesis_symbol , calc_sum_type , comma_symbol , calc_sum_type , right_parenthesis_symbol ;

(* pow( <calc-sum> , <calc-sum> ) *)
pow_fn = pow , left_parenthesis_symbol , calc_sum_type , comma_symbol , calc_sum_type , right_parenthesis_symbol ;

(* progress( <calc-sum> , <calc-sum> , <calc-sum> ) *)
progress_fn = progress , left_parenthesis_symbol , calc_sum_type , comma_symbol , calc_sum_type , comma_symbol , calc_sum_type , right_parenthesis_symbol ;

(* rem( <calc-sum> , <calc-sum> ) *)
rem_fn = rem , left_parenthesis_symbol , calc_sum_type , comma_symbol , calc_sum_type , right_parenthesis_symbol ;

(* round( <rounding-strategy>? , <calc-sum> , <calc-sum>? )
   <rounding-strategy> = nearest | up | down | to-0 | line-width *)
rounding_strategy_type = nearest | up | down | to_zero | line_width ;
round_fn = round , left_parenthesis_symbol , [ rounding_strategy_type , comma_symbol ] , calc_sum_type , [ comma_symbol , calc_sum_type ] , right_parenthesis_symbol ;

(* sign( <calc-sum> ) *)
sign_fn = sign , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* sin( <calc-sum> ) *)
sin_fn = sin , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* sqrt( <calc-sum> ) *)
sqrt_fn = sqrt , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;

(* tan( <calc-sum> ) *)
tan_fn = tan , left_parenthesis_symbol , calc_sum_type , right_parenthesis_symbol ;


(* ── Sizing / layout functions ──────────────────────────────────────────── *)

(* anchor( <anchor-name>? && <anchor-side> , <length-percentage>? )
   <anchor-name> = <dashed-ident>
   <anchor-side> = inside | outside | top | left | right | bottom | start | end
                 | self-start | self-end | <percentage> | center
   Note: && allows any order; grammar places optional anchor-name before anchor-side *)
anchor_side_type = inside | outside | top | left | right | bottom | start | end
                 | self_start | self_end | percentage_type | center ;
anchor_fn = anchor , left_parenthesis_symbol , [ dashed_ident_type ] , anchor_side_type , [ comma_symbol , length_percentage_type ] , right_parenthesis_symbol ;

(* anchor-size( [ <anchor-name> || <anchor-size-dimension> ]? , <length-percentage>? )
   <anchor-size-dimension> = width | height | block | inline | self-block | self-inline
   Note: || means one or both in any order; grammar places anchor-name before dimension *)
anchor_dim_type = width | height | block | inline | self_block | self_inline ;
anchor_size_fn = anchor_size , left_parenthesis_symbol , [ dashed_ident_type ] , [ anchor_dim_type ] , [ comma_symbol , length_percentage_type ] , right_parenthesis_symbol ;

(* calc-size( <calc-size-basis> , <calc-sum> )
   <calc-size-basis> = <size-keyword> | <calc-size()> | any | <calc-sum>
   <size-keyword>    = auto | min-content | max-content | fit-content | contain | stretch *)
size_keyword_type = auto | min_content | max_content | fit_content | contain | stretch ;
calc_size_basis_type = size_keyword_type | calc_size_fn | any | calc_sum_type ;
calc_size_fn = calc_size , left_parenthesis_symbol , calc_size_basis_type , comma_symbol , calc_sum_type , right_parenthesis_symbol ;

(* env( <custom-ident> <integer [0,∞]>* , <declaration-value>? )
   <declaration-value>: any sequence of CSS tokens — approximated as string_literal *)
declaration_value_type = string_literal ;
env_fn = env , left_parenthesis_symbol , custom_ident_type , { integer_type } , [ comma_symbol , declaration_value_type ] , right_parenthesis_symbol ;

(* fit-content( <length-percentage> ) *)
fit_content_fn = fit_content , left_parenthesis_symbol , length_percentage_type , right_parenthesis_symbol ;

(* minmax( <inflexible-breadth> , <track-breadth> )
   <track-breadth>      = <length-percentage> | <flex> | min-content | max-content | auto
   <inflexible-breadth> = <length-percentage> | min-content | max-content | auto
   <fixed-breadth>      = <length-percentage> *)
track_breadth_type = length_percentage_type | flex_type | min_content | max_content | auto ;
inflexible_breadth_type = length_percentage_type | min_content | max_content | auto ;
fixed_breadth_type = length_percentage_type ;
minmax_fn = minmax , left_parenthesis_symbol , ( inflexible_breadth_type | fixed_breadth_type ) , comma_symbol , track_breadth_type , right_parenthesis_symbol ;

(* repeat( ... ) — three forms for CSS Grid track lists
   track-repeat: repeat( <integer [1,∞]> , [ <line-names>? <track-size> ]+ <line-names>? )
   auto-repeat:  repeat( auto-fill | auto-fit , [ <line-names>? <track-size> ]+ <line-names>? )
   name-repeat:  repeat( <integer [1,∞]> | auto-fill , <line-names>+ )
   <track-size>  = <track-breadth> | minmax(...) | fit-content(...)
   <line-names>  = '[' <custom-ident>* ']' *)
track_size_type = track_breadth_type | minmax_fn | fit_content_fn ;
line_names_type = left_square_bracket_symbol , { custom_ident_type } , right_square_bracket_symbol ;
track_repeat_fn = repeat , left_parenthesis_symbol , integer_type , comma_symbol ,
    { line_names_type } , track_size_type , { line_names_type , track_size_type } , { line_names_type } , right_parenthesis_symbol ;
auto_repeat_fn = repeat , left_parenthesis_symbol , ( auto_fill | auto_fit ) , comma_symbol ,
    { line_names_type } , track_size_type , { line_names_type , track_size_type } , { line_names_type } , right_parenthesis_symbol ;
name_repeat_fn = repeat , left_parenthesis_symbol , ( integer_type | auto_fill ) , comma_symbol , line_names_type , { line_names_type } , right_parenthesis_symbol ;
repeat_fn = track_repeat_fn | auto_repeat_fn | name_repeat_fn ;

(* scroll( [ <scroller> || <axis> ]? )
   <scroller> = root | nearest | self
   Note: || means one or both in any order *)
scroller_type = root | nearest | self ;
scroll_fn = scroll , left_parenthesis_symbol , [ scroller_type ] , [ axis_type ] , right_parenthesis_symbol ;

(* view( [ <axis> || <view-timeline-inset> ]? )
   <view-timeline-inset> = [ auto | <length-percentage> ]{1,2}
   Note: || means one or both in any order *)
view_timeline_inset_type = ( auto | length_percentage_type ) , [ auto | length_percentage_type ] ;
view_fn = view , left_parenthesis_symbol , [ axis_type ] , [ view_timeline_inset_type ] , right_parenthesis_symbol ;


(* ── Color functions ─────────────────────────────────────────────────────── *)

(* dynamic-range-limit-mix( [ <'dynamic-range-limit'> && <percentage [0,100]> ]#{2,} )
   <dynamic-range-limit> = standard | no-limit | constrained | <dynamic-range-limit-mix()> *)
dynamic_range_limit_type = standard | no_limit | constrained | dynamic_range_limit_mix_fn ;
dynamic_range_limit_mix_item = dynamic_range_limit_type , percentage_type ;
dynamic_range_limit_mix_fn = dynamic_range_limit_mix , left_parenthesis_symbol ,
    dynamic_range_limit_mix_item , comma_symbol , dynamic_range_limit_mix_item ,
    { comma_symbol , dynamic_range_limit_mix_item } ,
  right_parenthesis_symbol ;

(* light-dark( <color> , <color> )            — color variant
   light-dark( [ <image> | none ] , [ <image> | none ] ) — image variant *)
light_dark_fn = light_dark , left_parenthesis_symbol , ( color_type | image_type | none ) , comma_symbol , ( color_type | image_type | none ) , right_parenthesis_symbol ;

(* palette-mix( <color-interpolation-method> , [ palette-entry && <percentage [0,100]>? ]#{2} )
   palette-entry = normal | light | dark | <palette-identifier> | <palette-mix()>
   <palette-identifier> = <dashed-ident>
   Note: && allows any order; grammar places entry before percentage *)
palette_entry_type = normal | light | dark | dashed_ident_type | palette_mix_fn ;
palette_mix_item = palette_entry_type , [ percentage_type ] ;
palette_mix_fn = palette_mix , left_parenthesis_symbol , color_interpolation_method_type , comma_symbol ,
    palette_mix_item , comma_symbol , palette_mix_item ,
  right_parenthesis_symbol ;


(* ── Content / value functions ───────────────────────────────────────────── *)

(* attr( <attr-name> <attr-type>? , <declaration-value>? )
   <attr-name>  = [ <ident> '|' ]? <ident>
   <attr-type>  = type( <syntax> ) | raw-string | number | <custom-ident>
   <syntax>     = complex typed-OM syntax string; approximated as string_literal *)
attr_name_type = [ ident_type , vertical_line_symbol ] , ident_type ;
attr_type_type = type_fn | raw_string | number | custom_ident_type ;
attr_fn = attr , left_parenthesis_symbol , attr_name_type , [ attr_type_type ] , [ comma_symbol , declaration_value_type ] , right_parenthesis_symbol ;

(* counter( <counter-name> , <counter-style>? )
   <counter-name>        = <custom-ident>
   <counter-style>       = <counter-style-name> | <symbols()>
   <counter-style-name>  = <custom-ident> *)
counter_style_type = custom_ident_type | symbols_fn ;
counter_fn = counter , left_parenthesis_symbol , custom_ident_type , [ comma_symbol , counter_style_type ] , right_parenthesis_symbol ;

(* counters( <counter-name> , <string> , <counter-style>? ) *)
counters_fn = counters , left_parenthesis_symbol , custom_ident_type , comma_symbol , string_type , [ comma_symbol , counter_style_type ] , right_parenthesis_symbol ;

(* layer( <layer-name> )
   <layer-name> = <ident> [ '.' <ident> ]* *)
layer_name_type = ident_type , { full_stop_symbol , ident_type } ;
layer_fn = layer , left_parenthesis_symbol , layer_name_type , right_parenthesis_symbol ;

(* paint( <ident> , <declaration-value>? ) *)
paint_fn = paint , left_parenthesis_symbol , ident_type , [ comma_symbol , declaration_value_type ] , right_parenthesis_symbol ;

(* symbols( <symbols-type>? [ <string> | <image> ]+ )
   <symbols-type> = cyclic | numeric | alphabetic | symbolic | fixed *)
symbols_fn = symbols , left_parenthesis_symbol , [ cyclic | numeric | alphabetic | symbolic | fixed ] , ( string_type | image_type ) , { string_type | image_type } , right_parenthesis_symbol ;

(* type( <string> ) *)
type_fn = type , left_parenthesis_symbol , string_type , right_parenthesis_symbol ;

(* url( <string> <url-modifier>* ) | <url-token>
   url-modifier and url-token are low-level CSS token forms; simplified to string argument *)
url_fn = url , left_parenthesis_symbol , string_type , right_parenthesis_symbol ;

(* var( <custom-property-name> , <declaration-value>? )
   <custom-property-name> = --<ident>  (same form as <dashed-ident>) *)
var_fn = var , left_parenthesis_symbol , dashed_ident_type , [ comma_symbol , declaration_value_type ] , right_parenthesis_symbol ;


(* ── Animation / motion functions ────────────────────────────────────────── *)

(* random( <random-key>? , <calc-sum> , <calc-sum> , <calc-sum>? )
   <random-key>       = auto | <random-cache-key> | fixed <number [0,1]>
   <random-cache-key> = <dashed-ident> || element-scoped
                      || [ property-scoped | property-index-scoped | <custom-ident> ] *)
random_cache_key_type = dashed_ident_type | element_scoped | property_scoped | property_index_scoped | custom_ident_type ;
random_key_type = auto | random_cache_key_type | ( fixed , number_type ) ;
random_fn = random , left_parenthesis_symbol , [ random_key_type , comma_symbol ] , calc_sum_type , comma_symbol , calc_sum_type , [ comma_symbol , calc_sum_type ] , right_parenthesis_symbol ;

(* ray( <angle> && <ray-size>? && contain? && [ at <position> ]? )
   <ray-size> = <radial-extent> | sides
   Note: && allows any order; grammar approximates angle-first canonical order *)
ray_size_type = radial_extent_type | sides ;
ray_fn = ray , left_parenthesis_symbol , angle_type , [ ray_size_type ] , [ contain ] , [ at , position_type ] , right_parenthesis_symbol ;
