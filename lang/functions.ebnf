(* CSS Function definitions
   Generated / hand-authored from docs/syntax/functions.txt and docs/syntax/datatypes.txt.
   See docs/GUIDE_TO_EBNF_TRANSFORMATION.md for transformation rationale.

   Functions already defined here were originally in datatype.ebnf; moved here
   so datatypes.ebnf can reference them. Cross-file references are resolved at
   compile time by the gluon compiler.
*)


(* <contrast-color()> *)
ContrastColorFn = contrast_color , left_parenthesis_symbol , ColorType , right_parenthesis_symbol ;

(* <sibling-count()> — takes no parameters; returns sibling count as integer *)
SiblingCountFn = sibling_count , left_parenthesis_symbol , right_parenthesis_symbol ;

(* <sibling-index()> — takes no parameters; returns element's 1-based sibling position *)
SiblingIndexFn = sibling_index , left_parenthesis_symbol , right_parenthesis_symbol ;

(* <device-cmyk()> *)
DeviceCmykFn = LegacyDeviceCmykSyntaxType | ModernDeviceCmykSyntaxType ;

(* <color-mix()> *)
ColorMixFn = color_mix , left_parenthesis_symbol , [ ColorInterpolationMethodType ] , comma_symbol , ColorMixFnItem , { comma_symbol , ColorMixFnItem } , right_parenthesis_symbol ;

(* <rgb()> *)
RgbFn = LegacyRgbSyntaxType | ModernRgbSyntaxType ;

(* <rgba()> *)
RgbaFn = LegacyRgbaSyntaxType | ModernRgbaSyntaxType ;

(* <hsl()> *)
HslFn = LegacyHslSyntaxType | ModernHslSyntaxType ;

(* <hsla()> *)
HslaFn = LegacyHslaSyntaxType | ModernHslaSyntaxType ;

(* <hwb()> *)
HwbFn = hwb , left_parenthesis_symbol , [ from , ColorType ] , ( HueType | none ) , ( percentage_type | number_type | none ) , ( percentage_type | number_type | none ) , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <lab()> *)
LabFn = lab , left_parenthesis_symbol , [ from , ColorType ] , ColorChannelValue , ColorChannelValue , ColorChannelValue , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <lch()> *)
LchFn = lch , left_parenthesis_symbol , [ from , ColorType ] , ColorChannelValue , ColorChannelValue , ( HueType | none | ident_type | MathFunctionType ) , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <oklab()> *)
OklabFn = oklab , left_parenthesis_symbol , [ from , ColorType ] , ColorChannelValue , ColorChannelValue , ColorChannelValue , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <oklch()> *)
OklchFn = oklch , left_parenthesis_symbol , [ from , ColorType ] , ColorChannelValue , ColorChannelValue , ( HueType | none | ident_type | MathFunctionType ) , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <ictcp()> *)
IctcpFn = ictcp , left_parenthesis_symbol , [ from , ColorType ] , ColorChannelValue , ColorChannelValue , ColorChannelValue , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <jzazbz()> *)
JzazbzFn = jzazbz , left_parenthesis_symbol , [ from , ColorType ] , ColorChannelValue , ColorChannelValue , ColorChannelValue , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <jzczhz()> *)
JzczhzFn = jzczhz , left_parenthesis_symbol , [ from , ColorType ] , ColorChannelValue , ColorChannelValue , ( HueType | none | ident_type | MathFunctionType ) , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <color-channel-value> — for relative color syntax: number, percentage, none, or channel ident *)
ColorChannelValue = percentage_type | number_type | none | ident_type | MathFunctionType | VarFn ;

(* <alpha()> *)
AlphaFn = alpha , left_parenthesis_symbol , from , ColorType , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <color()> *)
ColorFn = color , left_parenthesis_symbol , [ from , ColorType ] , ColorspaceParamsType , [ solidus_symbol , ( AlphaValueType | none ) ] , right_parenthesis_symbol ;

(* <hdr-color()> *)
HdrColorFn = color_hdr , left_parenthesis_symbol , HdrColorFnItem , comma_symbol , HdrColorFnItem , right_parenthesis_symbol ;

(* <superellipse()> *)
SuperellipseFn = superellipse , left_parenthesis_symbol , ( number_type | infinity | _infinity ) , right_parenthesis_symbol ;

(* <linear()> *)
LinearFn = linear , left_parenthesis_symbol , LinearFnItem , { comma_symbol , LinearFnItem } , right_parenthesis_symbol ;

(* <cubic-bezier()> *)
CubicBezierFn = cubic_bezier , left_parenthesis_symbol , CubicBezierFnItem , comma_symbol , CubicBezierFnItem , right_parenthesis_symbol ;

(* <steps()> *)
StepsFn = steps , left_parenthesis_symbol , integer_type , comma_symbol , [ StepPositionType ] , right_parenthesis_symbol ;

(* <blur()> *)
BlurFn = blur , left_parenthesis_symbol , [ length_type ] , right_parenthesis_symbol ;

(* <brightness()> *)
BrightnessFn = brightness , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <contrast()> *)
ContrastFn = contrast , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <drop-shadow()> *)
DropShadowFn = drop_shadow , left_parenthesis_symbol , ( [ ColorType ] , length_type , length_type , [ length_type ] ) , right_parenthesis_symbol ;

(* <grayscale()> *)
GrayscaleFn = grayscale , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <hue-rotate()> *)
HueRotateFn = hue_rotate , left_parenthesis_symbol , [ ( angle_type | digit_0_symbol ) ] , right_parenthesis_symbol ;

(* <invert()> *)
InvertFn = invert , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <opacity()> *)
OpacityFn = opacity , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <sepia()> *)
SepiaFn = sepia , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <saturate()> *)
SaturateFn = saturate , left_parenthesis_symbol , [ ( number_type | percentage_type ) ] , right_parenthesis_symbol ;

(* <linear-gradient()> *)
LinearGradientFn = linear_gradient , left_parenthesis_symbol , LinearGradientSyntaxType , right_parenthesis_symbol ;

(* <repeating-linear-gradient()> *)
RepeatingLinearGradientFn = repeating_linear_gradient , left_parenthesis_symbol , LinearGradientSyntaxType , right_parenthesis_symbol ;

(* <radial-gradient()> *)
RadialGradientFn = radial_gradient , left_parenthesis_symbol , RadialGradientSyntaxType , right_parenthesis_symbol ;

(* <repeating-radial-gradient()> *)
RepeatingRadialGradientFn = repeating_radial_gradient , left_parenthesis_symbol , RadialGradientSyntaxType , right_parenthesis_symbol ;

(* <conic-gradient()> *)
ConicGradientFn = conic_gradient , left_parenthesis_symbol , ConicGradientSyntaxType , right_parenthesis_symbol ;

(* <repeating-conic-gradient()> *)
RepeatingConicGradientFn = repeating_conic_gradient , left_parenthesis_symbol , ConicGradientSyntaxType , right_parenthesis_symbol ;

(* <image()> *)
ImageFn = image , left_parenthesis_symbol , [ ImageTagsType ] , (* ! at-least-one *) [ ImageSrcType ] , comma_symbol , [ ColorType ] , right_parenthesis_symbol ;

(* <image-set()> *)
ImageSetFn = image_set , left_parenthesis_symbol , ImageSetOptionType , { comma_symbol , ImageSetOptionType } , right_parenthesis_symbol ;

(* <cross-fade()> *)
CrossFadeFn = cross_fade , left_parenthesis_symbol , CfImageType , { comma_symbol , CfImageType } , right_parenthesis_symbol ;

(* <element()> *)
ElementFn = element , left_parenthesis_symbol , IdSelectorType , right_parenthesis_symbol ;

(* scale3d( [ <number> | <percentage> ]#{3} ) *)
Scale3dFn =
  scale3d , left_parenthesis_symbol ,
    ( number_type | percentage_type ) , comma_symbol ,
    ( number_type | percentage_type ) , comma_symbol ,
    ( number_type | percentage_type ) ,
  right_parenthesis_symbol ;

(* scale( <number> , <number>? ) *)
ScaleFn = scale , left_parenthesis_symbol , number_type , [ comma_symbol , number_type ] , right_parenthesis_symbol ;

(* scaleX( <number> ) *)
ScalexFn = scaleX , left_parenthesis_symbol , number_type , right_parenthesis_symbol ;

(* scaleY( <number> ) *)
ScaleyFn = scaleY , left_parenthesis_symbol , number_type , right_parenthesis_symbol ;

(* scaleZ( [ <number> | <percentage> ] ) *)
ScalezFn = scaleZ , left_parenthesis_symbol , ( number_type | percentage_type ) , right_parenthesis_symbol ;

(* translate3d( <length-percentage> , <length-percentage> , <length> ) *)
Translate3dFn =
  translate3d , left_parenthesis_symbol ,
    LengthPercentageType , comma_symbol ,
    LengthPercentageType , comma_symbol ,
    length_type ,
  right_parenthesis_symbol ;

(* translate( <length-percentage> , <length-percentage>? ) *)
TranslateFn = translate , left_parenthesis_symbol , LengthPercentageType , [ comma_symbol , LengthPercentageType ] , right_parenthesis_symbol ;

(* translateX( <length-percentage> ) *)
TranslatexFn = translateX , left_parenthesis_symbol , LengthPercentageType , right_parenthesis_symbol ;

(* translateY( <length-percentage> ) *)
TranslateyFn = translateY , left_parenthesis_symbol , LengthPercentageType , right_parenthesis_symbol ;

(* translateZ( <length> ) *)
TranslatezFn = translateZ , left_parenthesis_symbol , length_type , right_parenthesis_symbol ;

(* rotate3d( <number> , <number> , <number> , [ <angle> | <0> ] ) *)
Rotate3dFn =
  rotate3d , left_parenthesis_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    ( angle_type | digit_0_symbol ) ,
  right_parenthesis_symbol ;

(* rotate( [ <angle> | <0> ] ) *)
RotateFn = rotate , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* rotateX( [ <angle> | <0> ] ) *)
RotatexFn = rotateX , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* rotateY( [ <angle> | <0> ] ) *)
RotateyFn = rotateY , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* rotateZ( [ <angle> | <0> ] ) *)
RotatezFn = rotateZ , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* skew( [ <angle> | <0> ] , [ <angle> | <0> ]? ) *)
SkewFn = skew , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , [ comma_symbol , ( angle_type | digit_0_symbol ) ] , right_parenthesis_symbol ;

(* skewX( [ <angle> | <0> ] ) *)
SkewxFn = skewX , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* skewY( [ <angle> | <0> ] ) *)
SkewyFn = skewY , left_parenthesis_symbol , ( angle_type | digit_0_symbol ) , right_parenthesis_symbol ;

(* matrix3d( <number>#{16} ) — 4×4 homogeneous matrix, 16 comma-separated numbers *)
Matrix3dFn =
  matrix3d , left_parenthesis_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol , number_type , comma_symbol , number_type ,
  right_parenthesis_symbol ;

(* matrix( <number>#{6} ) — 2D homogeneous matrix, 6 comma-separated numbers *)
MatrixFn =
  matrix , left_parenthesis_symbol ,
    number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type , comma_symbol ,
    number_type , comma_symbol , number_type ,
  right_parenthesis_symbol ;

(* perspective( [ <length [0,∞]> | none ] ) *)
PerspectiveFn = perspective , left_parenthesis_symbol , ( length_type | none ) , right_parenthesis_symbol ;

(* inset( <length-percentage>{1,4} [ round <border-radius> ]? ) *)
InsetFn = inset , left_parenthesis_symbol ,
    LengthPercentageType , [ LengthPercentageType ] , [ LengthPercentageType ] , [ LengthPercentageType ] ,
    [ round , BorderRadiusType ] ,
  right_parenthesis_symbol ;

(* circle( <radial-size>? [ at <position> ]? ) *)
CircleFn = circle , left_parenthesis_symbol , [ RadialSizeType ] , [ at , PositionType ] , right_parenthesis_symbol ;

(* ellipse( <radial-size>? [ at <position> ]? ) *)
EllipseFn = ellipse , left_parenthesis_symbol , [ RadialSizeType ] , [ at , PositionType ] , right_parenthesis_symbol ;

(* polygon( <fill-rule>? [ round <length> ]? , [ <length-percentage> <length-percentage> ]# ) *)
PolygonFn = polygon , left_parenthesis_symbol ,
    [ FillRuleType ] , [ round , length_type ] , comma_symbol ,
    LengthPercentageType , LengthPercentageType , { comma_symbol , LengthPercentageType , LengthPercentageType } ,
  right_parenthesis_symbol ;

(* path( <fill-rule>? , <string> )  — comma only present when fill-rule given *)
PathFn = path , left_parenthesis_symbol , [ FillRuleType , comma_symbol ] , string_type , right_parenthesis_symbol ;

(* rect( [ <length-percentage> | auto ]{4} [ round <border-radius> ]? ) *)
RectFn = rect , left_parenthesis_symbol ,
    ( LengthPercentageType | auto ) , ( LengthPercentageType | auto ) ,
    ( LengthPercentageType | auto ) , ( LengthPercentageType | auto ) ,
    [ round , BorderRadiusType ] ,
  right_parenthesis_symbol ;

(* xywh( <length-percentage>{2} <length-percentage>{2} [ round <border-radius> ]? ) *)
XywhFn = xywh , left_parenthesis_symbol ,
    LengthPercentageType , LengthPercentageType ,
    LengthPercentageType , LengthPercentageType ,
    [ round , BorderRadiusType ] ,
  right_parenthesis_symbol ;

(* ── shape() ─────────────────────────────────────────────────────────────── *)

(* shape( <fill-rule>? from <position> , <shape-command># ) *)
ShapeFn = shape , left_parenthesis_symbol ,
    [ FillRuleType ] , from , PositionType , comma_symbol ,
    ShapeCommandType , { comma_symbol , ShapeCommandType } ,
  right_parenthesis_symbol ;


(* ── Math functions ─────────────────────────────────────────────────────── *)

(* abs( <calc-sum> ) *)
AbsFn = abs , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* acos( <calc-sum> ) *)
AcosFn = acos , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* asin( <calc-sum> ) *)
AsinFn = asin , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* atan( <calc-sum> ) *)
AtanFn = atan , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* atan2( <calc-sum> , <calc-sum> ) *)
Atan2Fn = atan2 , left_parenthesis_symbol , CalcSumType , comma_symbol , CalcSumType , right_parenthesis_symbol ;

(* calc( <calc-sum> ) *)
CalcFn = calc , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* clamp( [ <calc-sum> | none ] , <calc-sum> , [ <calc-sum> | none ] ) *)
ClampFn = clamp , left_parenthesis_symbol , ( CalcSumType | none ) , comma_symbol , CalcSumType , comma_symbol , ( CalcSumType | none ) , right_parenthesis_symbol ;

(* cos( <calc-sum> ) *)
CosFn = cos , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* exp( <calc-sum> ) *)
ExpFn = exp , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* hypot( <calc-sum># ) *)
HypotFn = hypot , left_parenthesis_symbol , CalcSumType , { comma_symbol , CalcSumType } , right_parenthesis_symbol ;

(* log( <calc-sum> , <calc-sum>? ) *)
LogFn = log , left_parenthesis_symbol , CalcSumType , [ comma_symbol , CalcSumType ] , right_parenthesis_symbol ;

(* max( <calc-sum># ) *)
MaxFn = max , left_parenthesis_symbol , CalcSumType , { comma_symbol , CalcSumType } , right_parenthesis_symbol ;

(* min( <calc-sum># ) *)
MinFn = min , left_parenthesis_symbol , CalcSumType , { comma_symbol , CalcSumType } , right_parenthesis_symbol ;

(* mod( <calc-sum> , <calc-sum> ) *)
ModFn = mod , left_parenthesis_symbol , CalcSumType , comma_symbol , CalcSumType , right_parenthesis_symbol ;

(* pow( <calc-sum> , <calc-sum> ) *)
PowFn = pow , left_parenthesis_symbol , CalcSumType , comma_symbol , CalcSumType , right_parenthesis_symbol ;

(* progress( <calc-sum> , <calc-sum> , <calc-sum> ) *)
ProgressFn = progress , left_parenthesis_symbol , CalcSumType , comma_symbol , CalcSumType , comma_symbol , CalcSumType , right_parenthesis_symbol ;

(* rem( <calc-sum> , <calc-sum> ) *)
RemFn = rem , left_parenthesis_symbol , CalcSumType , comma_symbol , CalcSumType , right_parenthesis_symbol ;

(* round( <rounding-strategy>? , <calc-sum> , <calc-sum>? )
   <rounding-strategy> = nearest | up | down | to-0 | line-width *)
RoundingStrategyType = nearest | up | down | to_zero | line_width ;
RoundFn = round , left_parenthesis_symbol , [ RoundingStrategyType , comma_symbol ] , CalcSumType , [ comma_symbol , CalcSumType ] , right_parenthesis_symbol ;

(* sign( <calc-sum> ) *)
SignFn = sign , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* sin( <calc-sum> ) *)
SinFn = sin , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* sqrt( <calc-sum> ) *)
SqrtFn = sqrt , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;

(* tan( <calc-sum> ) *)
TanFn = tan , left_parenthesis_symbol , CalcSumType , right_parenthesis_symbol ;


(* ── Sizing / layout functions ──────────────────────────────────────────── *)

(* anchor( <anchor-name>? && <anchor-side> , <length-percentage>? )
   <anchor-name> = <dashed-ident>
   <anchor-side> = inside | outside | top | left | right | bottom | start | end
                 | self-start | self-end | <percentage> | center
   Note: && allows any order; grammar places optional anchor-name before anchor-side *)
AnchorSideType = inside | outside | top | left | right | bottom | start | end
                 | self_start | self_end | percentage_type | center ;
AnchorFn = anchor , left_parenthesis_symbol , [ dashed_ident_type ] , AnchorSideType , [ comma_symbol , LengthPercentageType ] , right_parenthesis_symbol ;

(* anchor-size( [ <anchor-name> || <anchor-size-dimension> ]? , <length-percentage>? )
   <anchor-size-dimension> = width | height | block | inline | self-block | self-inline
   Note: || means one or both in any order; grammar places anchor-name before dimension *)
AnchorDimType = width | height | block | inline | self_block | self_inline ;
AnchorSizeFn = anchor_size , left_parenthesis_symbol , [ dashed_ident_type ] , [ AnchorDimType ] , [ comma_symbol , LengthPercentageType ] , right_parenthesis_symbol ;

(* calc-size( <calc-size-basis> , <calc-sum> )
   <calc-size-basis> = <size-keyword> | <calc-size()> | any | <calc-sum>
   <size-keyword>    = auto | min-content | max-content | fit-content | contain | stretch *)
SizeKeywordType = auto | min_content | max_content | fit_content | contain | stretch ;
CalcSizeBasisType = SizeKeywordType | CalcSizeFn | any | CalcSumType ;
CalcSizeFn = calc_size , left_parenthesis_symbol , CalcSizeBasisType , comma_symbol , CalcSumType , right_parenthesis_symbol ;

(* env( <custom-ident> <integer [0,∞]>* , <declaration-value>? )
   <declaration-value>: any sequence of CSS tokens — approximated as string_literal *)
DeclarationValueType = string_literal ;
EnvFn = env , left_parenthesis_symbol , custom_ident_type , { integer_type } , [ comma_symbol , DeclarationValueType ] , right_parenthesis_symbol ;

(* fit-content( <length-percentage> ) *)
FitContentFn = fit_content , left_parenthesis_symbol , LengthPercentageType , right_parenthesis_symbol ;

(* minmax( <inflexible-breadth> , <track-breadth> )
   <track-breadth>      = <length-percentage> | <flex> | min-content | max-content | auto
   <inflexible-breadth> = <length-percentage> | min-content | max-content | auto
   <fixed-breadth>      = <length-percentage> *)
TrackBreadthType = LengthPercentageType | flex_type | min_content | max_content | auto ;
InflexibleBreadthType = LengthPercentageType | min_content | max_content | auto ;
FixedBreadthType = LengthPercentageType ;
MinmaxFn = minmax , left_parenthesis_symbol , ( InflexibleBreadthType | FixedBreadthType ) , comma_symbol , TrackBreadthType , right_parenthesis_symbol ;

(* repeat( ... ) — three forms for CSS Grid track lists
   track-repeat: repeat( <integer [1,∞]> , [ <line-names>? <track-size> ]+ <line-names>? )
   auto-repeat:  repeat( auto-fill | auto-fit , [ <line-names>? <track-size> ]+ <line-names>? )
   name-repeat:  repeat( <integer [1,∞]> | auto-fill , <line-names>+ )
   <track-size>  = <track-breadth> | minmax(...) | fit-content(...)
   <line-names>  = '[' <custom-ident>* ']' *)
TrackSizeType = TrackBreadthType | MinmaxFn | FitContentFn ;
LineNamesType = left_square_bracket_symbol , { custom_ident_type } , right_square_bracket_symbol ;
TrackRepeatFn = repeat , left_parenthesis_symbol , integer_type , comma_symbol ,
    { LineNamesType } , TrackSizeType , { LineNamesType , TrackSizeType } , { LineNamesType } , right_parenthesis_symbol ;
AutoRepeatFn = repeat , left_parenthesis_symbol , ( auto_fill | auto_fit ) , comma_symbol ,
    { LineNamesType } , TrackSizeType , { LineNamesType , TrackSizeType } , { LineNamesType } , right_parenthesis_symbol ;
NameRepeatFn = repeat , left_parenthesis_symbol , ( integer_type | auto_fill ) , comma_symbol , LineNamesType , { LineNamesType } , right_parenthesis_symbol ;
RepeatFn = TrackRepeatFn | AutoRepeatFn | NameRepeatFn ;

(* scroll( [ <scroller> || <axis> ]? )
   <scroller> = root | nearest | self
   Note: || means one or both in any order *)
ScrollerType = root | nearest | self ;
ScrollFn = scroll , left_parenthesis_symbol , [ ScrollerType ] , [ AxisType ] , right_parenthesis_symbol ;

(* view( [ <axis> || <view-timeline-inset> ]? )
   <view-timeline-inset> = [ auto | <length-percentage> ]{1,2}
   Note: || means one or both in any order *)
ViewTimelineInsetType = ( auto | LengthPercentageType ) , [ auto | LengthPercentageType ] ;
ViewFn = view , left_parenthesis_symbol , [ AxisType ] , [ ViewTimelineInsetType ] , right_parenthesis_symbol ;


(* ── Color functions ─────────────────────────────────────────────────────── *)

(* dynamic-range-limit-mix( [ <'dynamic-range-limit'> && <percentage [0,100]> ]#{2,} )
   <dynamic-range-limit> = standard | no-limit | constrained | <dynamic-range-limit-mix()> *)
DynamicRangeLimitType = standard | no_limit | constrained | DynamicRangeLimitMixFn ;
DynamicRangeLimitMixItem = DynamicRangeLimitType , percentage_type ;
DynamicRangeLimitMixFn = dynamic_range_limit_mix , left_parenthesis_symbol ,
    DynamicRangeLimitMixItem , comma_symbol , DynamicRangeLimitMixItem ,
    { comma_symbol , DynamicRangeLimitMixItem } ,
  right_parenthesis_symbol ;

(* light-dark( <color> , <color> )            — color variant
   light-dark( [ <image> | none ] , [ <image> | none ] ) — image variant *)
LightDarkFn = light_dark , left_parenthesis_symbol , ( ColorType | ImageType | none ) , comma_symbol , ( ColorType | ImageType | none ) , right_parenthesis_symbol ;

(* palette-mix( <color-interpolation-method> , [ palette-entry && <percentage [0,100]>? ]#{2} )
   palette-entry = normal | light | dark | <palette-identifier> | <palette-mix()>
   <palette-identifier> = <dashed-ident>
   Note: && allows any order; grammar places entry before percentage *)
PaletteEntryType = normal | light | dark | dashed_ident_type | PaletteMixFn ;
PaletteMixItem = PaletteEntryType , [ percentage_type ] ;
PaletteMixFn = palette_mix , left_parenthesis_symbol , ColorInterpolationMethodType , comma_symbol ,
    PaletteMixItem , comma_symbol , PaletteMixItem ,
  right_parenthesis_symbol ;


(* ── Content / value functions ───────────────────────────────────────────── *)

(* attr( <attr-name> <attr-type>? , <declaration-value>? )
   <attr-name>  = [ <ident> '|' ]? <ident>
   <attr-type>  = type( <syntax> ) | raw-string | number | <custom-ident>
   <syntax>     = complex typed-OM syntax string; approximated as string_literal *)
AttrNameType = [ ident_type , vertical_line_symbol ] , ident_type ;
AttrTypeType = TypeFn | raw_string | number | custom_ident_type ;
AttrFn = attr , left_parenthesis_symbol , AttrNameType , [ AttrTypeType ] , [ comma_symbol , DeclarationValueType ] , right_parenthesis_symbol ;

(* counter( <counter-name> , <counter-style>? )
   <counter-name>        = <custom-ident>
   <counter-style>       = <counter-style-name> | <symbols()>
   <counter-style-name>  = <custom-ident> *)
CounterStyleType = custom_ident_type | SymbolsFn ;
CounterFn = counter , left_parenthesis_symbol , custom_ident_type , [ comma_symbol , CounterStyleType ] , right_parenthesis_symbol ;

(* counters( <counter-name> , <string> , <counter-style>? ) *)
CountersFn = counters , left_parenthesis_symbol , custom_ident_type , comma_symbol , string_type , [ comma_symbol , CounterStyleType ] , right_parenthesis_symbol ;

(* layer( <layer-name> )
   <layer-name> = <ident> [ '.' <ident> ]* *)
LayerNameType = ident_type , { full_stop_symbol , ident_type } ;
LayerFn = layer , left_parenthesis_symbol , LayerNameType , right_parenthesis_symbol ;

(* paint( <ident> , <declaration-value>? ) *)
PaintFn = paint , left_parenthesis_symbol , ident_type , [ comma_symbol , DeclarationValueType ] , right_parenthesis_symbol ;

(* symbols( <symbols-type>? [ <string> | <image> ]+ )
   <symbols-type> = cyclic | numeric | alphabetic | symbolic | fixed *)
SymbolsFn = symbols , left_parenthesis_symbol , [ cyclic | numeric | alphabetic | symbolic | fixed ] , ( string_type | ImageType ) , { string_type | ImageType } , right_parenthesis_symbol ;

(* type( <string> ) *)
TypeFn = type , left_parenthesis_symbol , string_type , right_parenthesis_symbol ;

(* url( <string> <url-modifier>* ) | <url-token>
   url-modifier and url-token are low-level CSS token forms; simplified to string argument *)
UrlFn = url , left_parenthesis_symbol , string_type , right_parenthesis_symbol ;

(* var( <custom-Property-name> , <declaration-value>? )
   <custom-Property-name> = --<ident>  (same form as <dashed-ident>) *)
VarFn = var , left_parenthesis_symbol , dashed_ident_type , [ comma_symbol , DeclarationValueType ] , right_parenthesis_symbol ;


(* ── Animation / motion functions ────────────────────────────────────────── *)

(* random( <random-key>? , <calc-sum> , <calc-sum> , <calc-sum>? )
   <random-key>       = auto | <random-cache-key> | fixed <number [0,1]>
   <random-cache-key> = <dashed-ident> || element-scoped
                      || [ Property-scoped | Property-index-scoped | <custom-ident> ] *)
RandomCacheKeyType = dashed_ident_type | element_scoped | property_scoped | property_index_scoped | custom_ident_type ;
RandomKeyType = auto | RandomCacheKeyType | ( fixed , number_type ) ;
RandomFn = random , left_parenthesis_symbol , [ RandomKeyType , comma_symbol ] , CalcSumType , comma_symbol , CalcSumType , [ comma_symbol , CalcSumType ] , right_parenthesis_symbol ;

(* ray( <angle> && <ray-size>? && contain? && [ at <position> ]? )
   <ray-size> = <radial-extent> | sides
   Note: && allows any order; grammar approximates angle-first canonical order *)
RaySizeType = RadialExtentType | sides ;
RayFn = ray , left_parenthesis_symbol , angle_type , [ RaySizeType ] , [ contain ] , [ at , PositionType ] , right_parenthesis_symbol ;
