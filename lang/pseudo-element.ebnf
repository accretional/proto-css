(* pseudo-element.ebnf — CSS pseudo-element selectors
   Sources: MDN pseudo-element reference, CSS Selectors Level 4 / Pseudo-Elements Level 4 spec
            docs/data/pseudo-elements.json

   Naming convention: pe_ prefix for every pseudo-element rule.

   Circular-reference note:
     ::slotted() and ::cue() take compound-selector arguments.
     These resolve to CompoundSelector defined in selector.ebnf,
     which in turn includes PseudoElement via SimpleSelector.
     gluon compiles all files together so the mutual recursion resolves
     at grammar-compile time.

   Flagged rules (NOT implemented — see inline comments):
     None — all 29 pseudo-elements are implemented.
     The view-transition-* group shares a helper type (ViewTransitionArg)
     defined at the bottom of this file.
*)


(* ── Top-level union ─────────────────────────────────────────────────────── *)

PseudoElement =
    (* Vendor-prefixed (e.g. ::-ms-browse, ::-webkit-file-upload-button) *)
    PeVendor
    (* Generated content *)
    | PeBefore | PeAfter
    (* Display / layout *)
    | PeBackdrop | PeColumn | PeDetailsContent | PeFileSelectorButton
    (* Typography *)
    | PeFirstLetter | PeFirstLine | PePlaceholder
    (* List / marker *)
    | PeMarker | PeCheckmark
    (* Selection / highlight *)
    | PeSelection | PeHighlight | PeTargetText
    (* Spelling / grammar *)
    | PeSpellingError | PeGrammarError
    (* Shadow DOM *)
    | PePart | PeSlotted
    (* Web Components / picker *)
    | PePicker | PePickerIcon
    (* Scroll *)
    | PeScrollButton | PeScrollMarker | PeScrollMarkerGroup
    (* WebVTT *)
    | PeCue
    (* View transitions *)
    | PeViewTransition
    | PeViewTransitionGroup
    | PeViewTransitionImagePair
    | PeViewTransitionNew
    | PeViewTransitionOld ;


(* ── Generated content ───────────────────────────────────────────────────── *)

PeBefore = double_colon_symbol , before ;
PeAfter  = double_colon_symbol , after ;


(* ── Display / layout ────────────────────────────────────────────────────── *)

PeBackdrop           = double_colon_symbol , backdrop ;
PeColumn             = double_colon_symbol , column ;
PeDetailsContent    = double_colon_symbol , details_content ;
PeFileSelectorButton = double_colon_symbol , file_selector_button ;


(* ── Typography ──────────────────────────────────────────────────────────── *)

PeFirstLetter = double_colon_symbol , first_letter ;
PeFirstLine   = double_colon_symbol , first_line ;
PePlaceholder  = double_colon_symbol , placeholder ;


(* ── List / marker ───────────────────────────────────────────────────────── *)

PeMarker    = double_colon_symbol , marker ;
PeCheckmark = double_colon_symbol , checkmark ;


(* ── Selection / highlight ───────────────────────────────────────────────── *)

PeSelection  = double_colon_symbol , selection ;
PeTargetText = double_colon_symbol , target_text ;

(* ::highlight(<custom-ident>) — names a custom highlight registered via the
   CSS Custom Highlight API (HighlightRegistry). The argument is the highlight name. *)
PeHighlight = double_colon_symbol , highlight ,
               left_parenthesis_symbol , custom_ident_type , right_parenthesis_symbol ;


(* ── Spelling / grammar ──────────────────────────────────────────────────── *)

PeSpellingError = double_colon_symbol , spelling_error ;
PeGrammarError  = double_colon_symbol , grammar_error ;


(* ── Shadow DOM ──────────────────────────────────────────────────────────── *)

(* ::part(<ident>+) — one or more part names exposed by a shadow host element. *)
PePart = double_colon_symbol , part ,
          left_parenthesis_symbol , ident_type , { ident_type } , right_parenthesis_symbol ;

(* ::slotted(<compound-selector>) — elements placed into a shadow DOM slot. *)
PeSlotted = double_colon_symbol , slotted ,
             left_parenthesis_symbol , CompoundSelector , right_parenthesis_symbol ;


(* ── Web Components / picker ─────────────────────────────────────────────── *)

(* ::picker(<ident>) — targets the picker of a form control that has base appearance.
   Currently only "select" is supported as the ident value. *)
PePicker      = double_colon_symbol , picker ,
                 left_parenthesis_symbol , ident_type , right_parenthesis_symbol ;

PePickerIcon = double_colon_symbol , picker_icon ;


(* ── Scroll ──────────────────────────────────────────────────────────────── *)

(* ::scroll-button(<scroll-button-direction>)
   Selects scroll buttons generated on a scroll container.
   * = all scroll buttons; directional keywords select a specific one. *)
PeScrollButton = double_colon_symbol , scroll_button ,
                   left_parenthesis_symbol , ScrollButtonDirection , right_parenthesis_symbol ;

PeScrollMarker       = double_colon_symbol , scroll_marker ;
PeScrollMarkerGroup = double_colon_symbol , scroll_marker_group ;


(* ── WebVTT ──────────────────────────────────────────────────────────────── *)

(* ::cue | ::cue(<compound-selector>)
   Matches WebVTT cues. The optional argument is a compound selector that
   filters which cues are matched. WebVTT cue selectors are a subset of
   CSS compound selectors (no combinators). *)
PeCue = double_colon_symbol , cue ,
         [ left_parenthesis_symbol , CompoundSelector , right_parenthesis_symbol ] ;


(* ── View transitions ────────────────────────────────────────────────────── *)

PeViewTransition = double_colon_symbol , view_transition ;

(* ::view-transition-group(), ::view-transition-image-pair(),
   ::view-transition-new(), ::view-transition-old()
   all share the same argument syntax — see ViewTransitionArg below. *)
PeViewTransitionGroup      = double_colon_symbol , view_transition_group ,
                                 left_parenthesis_symbol , ViewTransitionArg , right_parenthesis_symbol ;
PeViewTransitionImagePair = double_colon_symbol , view_transition_image_pair ,
                                 left_parenthesis_symbol , ViewTransitionArg , right_parenthesis_symbol ;
PeViewTransitionNew        = double_colon_symbol , view_transition_new ,
                                 left_parenthesis_symbol , ViewTransitionArg , right_parenthesis_symbol ;
PeViewTransitionOld        = double_colon_symbol , view_transition_old ,
                                 left_parenthesis_symbol , ViewTransitionArg , right_parenthesis_symbol ;


(* ── Supporting types ────────────────────────────────────────────────────── *)

(* <scroll-button-direction>:
   * selects all scroll buttons; directional keywords select a specific one.
   next / prev are spec-defined but not yet browser-supported. *)
ScrollButtonDirection =
    asterisk_symbol
    | up | down | left | right
    | block_start | block_end | inline_start | inline_end ;

(* View-transition argument syntax:
     [ <pt-name-selector> <pt-class-selector>? ] | <pt-class-selector>
   <pt-name-selector> = * | <custom-ident>   (the view-transition-name value)
   <pt-class-selector> = . <custom-ident>    (the view-transition-class value, dot-prefixed)
   The two forms are:
     - a name (with optional class):  custom_ident [ . custom_ident ]
     - a class alone:                 . custom_ident
     - the universal selector:        * [ . custom_ident ] *)
PtNameSelector  = asterisk_symbol | custom_ident_type ;
PtClassSelector = full_stop_symbol , custom_ident_type ;

ViewTransitionArg =
    ( PtNameSelector , [ PtClassSelector ] )
    | PtClassSelector ;

(* Vendor-prefixed pseudo-elements: ::-webkit-*, ::-moz-*, ::-ms-*, etc. *)
PeVendor = double_colon_symbol , hyphen_symbol , ident_type ;

(* CompoundSelectorType is defined in pseudo-class.ebnf — shared alias. *)
