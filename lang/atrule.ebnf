(* CSS At-rule definitions
   Sources: MDN formal syntax, W3C CSS specifications
*)

(* ── at_rule — union used in css.ebnf ───────────────────────────────────── *)

at_rule =
    at_charset
    | at_color_profile
    | at_container
    | at_counter_style
    | at_custom_media
    | at_font_face
    | at_font_feature_values
    | at_font_palette_values
    | at_function
    | at_import
    | at_keyframes
    | at_layer
    | at_media
    | at_namespace
    | at_page
    | at_position_try
    | at_property
    | at_scope
    | at_starting_style
    | at_supports
    | at_view_transition ;


(* ── Placeholder types for sub-systems defined in other EBNF files ───────── *)
block_contents_type       = declaration_value_type ;  (* rules + declarations; defined with selectors *)
declaration_list_type     = declaration_value_type ;  (* descriptor block *)
rule_list_type            = declaration_value_type ;  (* list of rules *)
declaration_rule_list_type = declaration_value_type ; (* mixed declarations and rules *)
qualified_rule_list_type  = declaration_value_type ;  (* e.g. @keyframes block *)
media_query_list_type     = declaration_value_type ;  (* defined with @media *)
selector_list_type        = declaration_value_type ;  (* defined in selectors EBNF *)
any_value_type            = declaration_value_type ;  (* any CSS token sequence *)

(* ── Shared: general-enclosed (used in container/supports queries) ───────── *)
general_enclosed_type =
    custom_ident_type , left_parenthesis_symbol , [ any_value_type ] , right_parenthesis_symbol
    | left_parenthesis_symbol , [ any_value_type ] , right_parenthesis_symbol ;

(* ── Shared: @supports condition (used in @import and @supports) ─────────── *)
font_tech_atrule_type =
    features_opentype | features_aat | features_graphite
    | color_colrv0 | color_colrv1 | color_svg | color_sbix | color_cbdt
    | variations | palettes | incremental ;

font_format_atrule_type =
    string_type
    | collection | embedded_opentype | opentype
    | svg | truetype | woff | woff2 ;

supports_selector_fn_type      = selector , left_parenthesis_symbol , any_value_type , right_parenthesis_symbol ;
supports_font_tech_fn_type     = font_tech , left_parenthesis_symbol , font_tech_atrule_type , right_parenthesis_symbol ;
supports_font_format_fn_type   = font_format , left_parenthesis_symbol , font_format_atrule_type , right_parenthesis_symbol ;
supports_at_rule_fn_type       = at_rule , left_parenthesis_symbol , custom_ident_type , right_parenthesis_symbol ;
supports_named_feature_fn_type = named_feature , left_parenthesis_symbol , custom_ident_type , right_parenthesis_symbol ;
supports_env_fn_type           = env_fn ;
supports_decl_type             = left_parenthesis_symbol , declaration_value_type , right_parenthesis_symbol ;

supports_feature_type =
    supports_selector_fn_type
    | supports_font_tech_fn_type
    | supports_font_format_fn_type
    | supports_at_rule_fn_type
    | supports_named_feature_fn_type
    | supports_env_fn_type
    | supports_decl_type ;

supports_in_parens_type =
    left_parenthesis_symbol , supports_condition_type , right_parenthesis_symbol
    | supports_feature_type
    | general_enclosed_type ;

supports_condition_type =
    not , supports_in_parens_type
    | supports_in_parens_type , { and , supports_in_parens_type }
    | supports_in_parens_type , { or , supports_in_parens_type } ;

(* ── @charset ────────────────────────────────────────────────────────────── *)

(* Common IANA charset names. Use custom_ident_type for any other valid value. *)
charset_name_type =
    (* Unicode *)
    utf_8 | utf_16 | utf_16be | utf_16le
    | utf_32 | utf_32be | utf_32le | utf_7
    (* ASCII / Latin *)
    | us_ascii
    | iso_8859_1 | iso_8859_2 | iso_8859_3 | iso_8859_4
    | iso_8859_5 | iso_8859_6 | iso_8859_7 | iso_8859_8
    | iso_8859_9 | iso_8859_10 | iso_8859_11 | iso_8859_13
    | iso_8859_14 | iso_8859_15 | iso_8859_16
    (* Windows code pages *)
    | windows_874 | windows_1250 | windows_1251 | windows_1252
    | windows_1253 | windows_1254 | windows_1255 | windows_1256
    | windows_1257 | windows_1258
    (* East Asian *)
    | shift_jis | euc_jp | iso_2022_jp | iso_2022_jp_2
    | euc_kr | iso_2022_kr
    | gb2312 | gbk | gb18030
    | big5 | big5_hkscs
    (* Cyrillic *)
    | koi8_r | koi8_u
    (* Other *)
    | macintosh | tis_620 | ibm866 | ibm850
    (* Custom / non-standard *)
    | custom_ident_type ;

at_charset = commercial_at_symbol , charset , charset_name_type , semicolon_symbol ;

(* ── @color-profile ──────────────────────────────────────────────────────── *)

at_color_profile = commercial_at_symbol , color_profile , ( dashed_ident_type | device_cmyk ) , left_curly_bracket_symbol , declaration_list_type , right_curly_bracket_symbol ;

(* ── @container ──────────────────────────────────────────────────────────── *)

mf_lt_type         = [ less_than_sign_symbol ], equals_sign_symbol ;
mf_gt_type         = [ greater_than_sign_symbol ], equals_sign_symbol ;
mf_comparison_type = mf_lt_type | mf_gt_type | equals_sign_symbol ;

size_feature_type         = declaration_value_type ;  (* defined with media features *)
scroll_state_feature_type = declaration_value_type ;  (* defined with scroll state *)
style_feature_name_type   = custom_ident_type ;
style_feature_value_type  = declaration_value_type ;

style_feature_plain_type   = style_feature_name_type , colon_symbol , style_feature_value_type ;
style_feature_boolean_type = style_feature_name_type ;
style_range_value_type     = custom_property_name_type | style_feature_value_type ;
style_range_type =
    style_range_value_type , mf_comparison_type , style_range_value_type
    | style_range_value_type , mf_lt_type , style_range_value_type , mf_lt_type , style_range_value_type
    | style_range_value_type , mf_gt_type , style_range_value_type , mf_gt_type , style_range_value_type ;
style_feature_type = style_feature_plain_type | style_feature_boolean_type | style_range_type ;

style_in_parens_type =
    left_parenthesis_symbol , style_query_type , right_parenthesis_symbol
    | left_parenthesis_symbol , style_feature_type , right_parenthesis_symbol
    | general_enclosed_type ;

style_query_type =
    not , style_in_parens_type
    | style_in_parens_type , { and , style_in_parens_type }
    | style_in_parens_type , { or , style_in_parens_type }
    | style_feature_type ;

scroll_state_in_parens_type =
    left_parenthesis_symbol , scroll_state_query_type , right_parenthesis_symbol
    | left_parenthesis_symbol , scroll_state_feature_type , right_parenthesis_symbol
    | general_enclosed_type ;

scroll_state_query_type =
    not , scroll_state_in_parens_type
    | scroll_state_in_parens_type , { and , scroll_state_in_parens_type }
    | scroll_state_in_parens_type , { or , scroll_state_in_parens_type } ;

query_in_parens_type =
    left_parenthesis_symbol , container_query_type , right_parenthesis_symbol
    | left_parenthesis_symbol , size_feature_type , right_parenthesis_symbol
    | style , left_parenthesis_symbol , style_query_type , right_parenthesis_symbol
    | scroll_state , left_parenthesis_symbol , scroll_state_query_type , right_parenthesis_symbol
    | general_enclosed_type ;

container_query_type =
    not , query_in_parens_type
    | query_in_parens_type , { and , query_in_parens_type }
    | query_in_parens_type , { or , query_in_parens_type } ;

container_condition_type = [ custom_ident_type ] , container_query_type ;

at_container = commercial_at_symbol , container , container_condition_type , { comma_symbol , container_condition_type } , left_curly_bracket_symbol , block_contents_type , right_curly_bracket_symbol ;

(* ── @counter-style ──────────────────────────────────────────────────────── *)

(* <symbol> in the context of @counter-style descriptors (not the symbols() fn) *)
counter_style_symbol_type = string_type | image_type | custom_ident_type ;

counter_style_additive_symbols_type =
    integer_type , counter_style_symbol_type ,
    { comma_symbol , integer_type , counter_style_symbol_type } ;

counter_style_negative_type = counter_style_symbol_type , [ counter_style_symbol_type ] ;
counter_style_pad_type      = integer_type , counter_style_symbol_type ;
counter_style_range_value_type = integer_type | infinite ;
counter_style_range_type =
    counter_style_range_value_type , counter_style_range_value_type ,
    { comma_symbol , counter_style_range_value_type , counter_style_range_value_type }
    | auto ;

counter_style_speak_as_type =
    auto | bullets | numbers | words | spell_out
    | counter_style_name_type ;

counter_style_system_type =
    cyclic | numeric | alphabetic | symbolic | additive
    | ( fixed , [ integer_type ] )
    | ( extends , counter_style_name_type ) ;

at_counter_style = commercial_at_symbol , counter_style , custom_ident_type , left_curly_bracket_symbol , declaration_list_type , right_curly_bracket_symbol ;

(* ── @custom-media ───────────────────────────────────────────────────────── *)

at_custom_media = commercial_at_symbol , custom_media , dashed_ident_type , ( media_query_list_type | true | false ) , semicolon_symbol ;

(* ── @font-face ──────────────────────────────────────────────────────────── *)

font_face_src_type         = declaration_value_type ;  (* url() with optional format()/tech() hints *)
unicode_range_token_type   = custom_ident_type ;       (* e.g. U+0025, U+4??, U+0025-00FF *)

font_face_override_type    = normal | percentage_type ;   (* ascent/descent/line-gap override *)
font_face_display_type     = auto | block | swap | fallback | optional ;

font_face_style_desc_type  =
    auto | normal | italic | left | right
    | ( oblique , [ angle_type , [ angle_type ] ] ) ;

font_face_weight_desc_type =
    auto | font_weight_absolute_type | ( font_weight_absolute_type , font_weight_absolute_type ) ;

font_face_width_desc_type  = auto | font_width_css3_type | ( font_width_css3_type , font_width_css3_type ) ;

(* opentype_tag_type: defined in property.ebnf *)
font_face_feature_tag_value_type = opentype_tag_type , [ integer_type | on | off ] ;
font_face_feature_settings_type = normal | font_face_feature_tag_value_type , { comma_symbol , font_face_feature_tag_value_type } ;

at_font_face = commercial_at_symbol , font_face , left_curly_bracket_symbol , declaration_list_type , right_curly_bracket_symbol ;

(* ── @font-feature-values ────────────────────────────────────────────────── *)

at_font_feature_values = commercial_at_symbol , font_feature_values , font_family_name_type , { comma_symbol , font_family_name_type } , left_curly_bracket_symbol , declaration_rule_list_type , right_curly_bracket_symbol ;

(* ── @font-palette-values ────────────────────────────────────────────────── *)

font_palette_base_type = light | dark | integer_type ;
font_palette_override_colors_type = integer_type , color_type , { comma_symbol , integer_type , color_type } ;

at_font_palette_values = commercial_at_symbol , font_palette_values , dashed_ident_type , left_curly_bracket_symbol , declaration_list_type , right_curly_bracket_symbol ;

(* ── @function ───────────────────────────────────────────────────────────── *)

custom_property_name_type  = dashed_ident_type ;

syntax_type_name_atrule_type =
    angle | color | custom_ident | image | integer
    | length | length_percentage | number | percentage
    | resolution | string | time | url | transform_function ;

syntax_multiplier_atrule_type  = number_sign_symbol | plus_sign_symbol ;
(* syntax_single_component_type, syntax_component_type: defined in property.ebnf *)
css_type_atrule_type           = syntax_component_type | type_fn ;
function_parameter_type        = custom_property_name_type , [ css_type_atrule_type ] , [ colon_symbol , declaration_value_type ] ;

at_function =
    commercial_at_symbol , function , custom_ident_type , left_parenthesis_symbol , [ function_parameter_type , { comma_symbol , function_parameter_type } ] , right_parenthesis_symbol ,
    [ returns , css_type_atrule_type ] ,
    left_curly_bracket_symbol , declaration_rule_list_type , right_curly_bracket_symbol ;

(* ── @import ─────────────────────────────────────────────────────────────── *)

scope_start_type      = selector_list_type ;
scope_end_type        = selector_list_type ;
scope_boundaries_type =
    [ left_parenthesis_symbol , scope_start_type , right_parenthesis_symbol ] ,
    [ to , left_parenthesis_symbol , scope_end_type , right_parenthesis_symbol ] ;

supports_import_condition_type =
    supports , left_parenthesis_symbol , ( supports_condition_type | declaration_value_type ) , right_parenthesis_symbol ;

import_layer_type = layer | layer_fn ;
import_scope_type = scope | ( scope , left_parenthesis_symbol , ( scope_start_type | scope_boundaries_type ) , right_parenthesis_symbol ) ;

at_import =
    commercial_at_symbol , import , ( url_type | string_type ) ,
    [ import_layer_type ] ,
    [ import_scope_type ] ,
    [ supports_import_condition_type ] ,
    [ media_query_list_type ] ,
    semicolon_symbol ;

(* ── @keyframes ──────────────────────────────────────────────────────────── *)

(* keyframes_name_type: defined in property.ebnf *)

at_keyframes = commercial_at_symbol , keyframes , keyframes_name_type , left_curly_bracket_symbol , qualified_rule_list_type , right_curly_bracket_symbol ;

(* ── @layer ──────────────────────────────────────────────────────────────── *)

at_layer =
    ( commercial_at_symbol , layer , [ layer_name_type ] , left_curly_bracket_symbol , rule_list_type , right_curly_bracket_symbol )
    | ( commercial_at_symbol , layer , layer_name_type , { comma_symbol , layer_name_type } , semicolon_symbol ) ;

(* ── @media ──────────────────────────────────────────────────────────────── *)

at_media = commercial_at_symbol , media , media_query_list_type , left_curly_bracket_symbol , rule_list_type , right_curly_bracket_symbol ;

(* ── @namespace ──────────────────────────────────────────────────────────── *)

namespace_prefix_type = custom_ident_type ;

at_namespace = commercial_at_symbol , namespace , [ namespace_prefix_type ] , ( string_type | url_type ) , semicolon_symbol ;

(* ── @page ───────────────────────────────────────────────────────────────── *)

pseudo_page_type =
    colon_symbol , ( left | right | first | blank ) ;

page_selector_type =
    [ custom_ident_type ] , { pseudo_page_type } ;

page_size_type =
    a5 | a4 | a3 | b5 | b4 | jis_b5 | jis_b4
    | page_letter | legal | ledger ;

page_orientation_type = upright | rotate_left | rotate_right ;

page_size_descriptor_type =
    length_type , [ length_type ]
    | auto
    | page_size_type
    | page_size_type , ( portrait | landscape )
    | portrait | landscape ;

at_page = commercial_at_symbol , page , [ page_selector_type , { comma_symbol , page_selector_type } ] , left_curly_bracket_symbol , declaration_rule_list_type , right_curly_bracket_symbol ;

(* ── @position-try ───────────────────────────────────────────────────────── *)

at_position_try = commercial_at_symbol , position_try , dashed_ident_type , left_curly_bracket_symbol , declaration_list_type , right_curly_bracket_symbol ;

(* ── @property ───────────────────────────────────────────────────────────── *)

at_property = commercial_at_symbol , property_kw , custom_property_name_type , left_curly_bracket_symbol , declaration_list_type , right_curly_bracket_symbol ;

(* ── @scope ──────────────────────────────────────────────────────────────── *)

at_scope = commercial_at_symbol , scope , [ scope_boundaries_type ] , left_curly_bracket_symbol , block_contents_type , right_curly_bracket_symbol ;

(* ── @starting-style ─────────────────────────────────────────────────────── *)

at_starting_style = commercial_at_symbol , starting_style , left_curly_bracket_symbol , rule_list_type , right_curly_bracket_symbol ;

(* ── @supports ───────────────────────────────────────────────────────────── *)

at_supports = commercial_at_symbol , supports , supports_condition_type , left_curly_bracket_symbol , rule_list_type , right_curly_bracket_symbol ;

(* ── @view-transition ────────────────────────────────────────────────────── *)

at_view_transition = commercial_at_symbol , view_transition , left_curly_bracket_symbol , declaration_list_type , right_curly_bracket_symbol ;

