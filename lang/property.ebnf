PositionVisibilityProp = always | ( [ anchors_valid ] , [ anchors_visible ] , [ no_overflow ] ) ;

(* position *)
PositionProp = static | relative | absolute | sticky | fixed | RunningFn ;

(* print-color-adjust *)
PrintColorAdjustProp = economy | exact ;

(* quotes *)
QuotesProp = auto | none | match_parent | QuotesPropItem , { QuotesPropItem } ;
QuotesPropItem = string_type , string_type ;

(* r *)
RProp = LengthPercentageType ;

(* resize *)
ResizeProp = none | both | horizontal | vertical | block | inline ;

(* right *)
RightProp = auto | LengthPercentageType | AnchorFn | AnchorSizeFn ;

(* rotate *)
RotateProp = none | angle_type | ( lowercase_x_symbol | lowercase_y_symbol | lowercase_z_symbol | number_type , number_type , number_type ) , angle_type ;

(* row-gap *)
RowGapProp = normal | LengthPercentageType | LineWidthType ;

(* ruby-align *)
RubyAlignProp = start | center | space_between | space_around ;

(* ruby-overhang *)
RubyOverhangProp = auto | spaces ;

(* ruby-position *)
RubyPositionProp = ( [ alternate ] , [ ( over | under ) ] ) | inter_character ;

(* rx *)
RxProp = LengthPercentageType | auto ;

(* ry *)
RyProp = LengthPercentageType | auto ;

(* scale *)
ScaleProp = none | ScalePropItem , [ ScalePropItem ] , [ ScalePropItem ] ;
ScalePropItem = ( number_type | percentage_type ) ;

(* scroll-behavior *)
ScrollBehaviorProp = auto | smooth ;

(* scroll-initial-target *)
ScrollInitialTargetProp = none | nearest ;

(* scroll-margin-block-end *)
ScrollMarginBlockEndProp = length_type ;

(* scroll-margin-block-start *)
ScrollMarginBlockStartProp = length_type ;

(* scroll-margin-block *)
ScrollMarginBlockProp = length_type , [ length_type ] ;

(* scroll-margin-bottom *)
ScrollMarginBottomProp = length_type ;

(* scroll-margin-inline-end *)
ScrollMarginInlineEndProp = length_type ;

(* scroll-margin-inline-start *)
ScrollMarginInlineStartProp = length_type ;

(* scroll-margin-inline *)
ScrollMarginInlineProp = length_type , [ length_type ] ;

(* scroll-margin-left *)
ScrollMarginLeftProp = length_type ;

(* scroll-margin-right *)
ScrollMarginRightProp = length_type ;

(* scroll-margin-top *)
ScrollMarginTopProp = length_type ;

(* scroll-margin *)
ScrollMarginProp = length_type , [ length_type ] , [ length_type ] , [ length_type ] ;

(* scroll-marker-group *)
ScrollMarkerGroupProp = none | ( [ ( before | after ) ] , [ ( links | tabs ) ] ) ;

(* scroll-padding-block-end *)
ScrollPaddingBlockEndProp = auto | LengthPercentageType ;

(* scroll-padding-block-start *)
ScrollPaddingBlockStartProp = auto | LengthPercentageType ;

