MinWidthProp = auto | LengthPercentageType | min_content | max_content | FitContentFn | CalcSizeFn | AnchorSizeFn | stretch | fit_content | contain ;

(* mix-blend-mode *)
MixBlendModeProp = BlendModeType | plus_lighter ;

(* object-fit *)
ObjectFitProp = fill | none | [ ( contain | cover ) ] , [ scale_down ] ;

