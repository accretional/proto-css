TextBoxProp = normal | [ TextBoxTrimProp ] , [ TextBoxEdgeProp ] ;

(* text-combine-upright *)
TextCombineUprightProp = none | all | digits , [ integer_type ] ;

(* text-decoration-color *)
TextDecorationColorProp = ColorType ;

(* text-decoration-inset *)
TextDecorationInsetProp = length_type , [ length_type ] | auto ;

(* text-decoration-line *)
TextDecorationLineProp = none | ( [ underline ] , [ overline ] , [ line_through ] , [ blink ] ) | spelling_error | grammar_error ;

(* text-decoration-skip-ink *)
TextDecorationSkipInkProp = auto | none | all ;

(* text-decoration-skip *)
TextDecorationSkipProp = none | auto ;

(* text-decoration-style *)
TextDecorationStyleProp = solid | double | dotted | dashed | wavy ;

(* text-decoration-thickness *)
TextDecorationThicknessProp = auto | from_font | LengthPercentageType | LineWidthType ;

(* text-decoration *)
TextDecorationProp = [ TextDecorationLineProp ] , [ TextDecorationThicknessProp ] , [ TextDecorationStyleProp ] , [ TextDecorationColorProp ] ;

(* text-emphasis-color *)
TextEmphasisColorProp = ColorType ;

(* text-emphasis-position *)
TextEmphasisPositionProp = ( over | under ) , [ ( right | left ) ] ;

