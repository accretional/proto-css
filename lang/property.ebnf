OverscrollBehaviorBlockProp = contain | none | auto | chain ;

(* overscroll-behavior-inline *)
OverscrollBehaviorInlineProp = contain | none | auto | chain ;

(* overscroll-behavior-x *)
OverscrollBehaviorXProp = contain | none | auto | chain ;

