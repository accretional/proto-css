OutlineProp = [ OutlineWidthProp ] , [ OutlineStyleProp ] , [ OutlineColorProp ] ;

(* overflow-anchor *)
OverflowAnchorProp = auto | none ;

(* overflow-block *)
OverflowBlockProp = visible | hidden | clip | scroll | auto ;

(* overflow-clip-margin *)
OverflowClipMarginProp = [ VisualBoxType ] , [ length_type ] ;

(* overflow-inline *)
OverflowInlineProp = visible | hidden | clip | scroll | auto ;

