OffsetPathProp = none | [ OffsetPathType ] , [ CoordBoxType ] ;

(* offset-position *)
OffsetPositionProp = normal | auto | PositionType ;

(* offset-rotate *)
OffsetRotateProp = [ ( auto | reverse ) ] , [ angle_type ] ;

(* offset *)
OffsetProp = (* ! at-least-one *) [ OffsetPositionProp ] , [ OffsetPathProp , [ ( [ OffsetDistanceProp ] , [ OffsetRotateProp ] ) ] ] , [ solidus_symbol , OffsetAnchorProp ] ;

(* opacity *)
OpacityProp = OpacityValueType ;

(* order *)
OrderProp = integer_type ;

(* orphans *)
OrphansProp = integer_type ;

(* outline-color *)
OutlineColorProp = auto | BorderTopColorProp ;

