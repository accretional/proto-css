TextEmphasisStyleProp = none | ( [ ( filled | open ) ] , [ ( dot | circle | double_circle | triangle | sesame ) ] ) | string_type ;

(* text-emphasis *)
TextEmphasisProp = [ TextEmphasisStyleProp ] , [ TextEmphasisColorProp ] ;

(* text-indent *)
TextIndentProp = LengthPercentageType , [ hanging ] , [ each_line ] ;

(* text-justify *)
TextJustifyProp = [ ( auto | none | inter_word | inter_character | ruby ) ] , [ no_compress ] ;

(* text-orientation *)
TextOrientationProp = mixed | upright | sideways ;

(* text-overflow *)
TextOverflowProp = TextOverflowPropItem , [ TextOverflowPropItem ] ;
TextOverflowPropItem = ( clip | ellipsis | string_type | fade | FadeFn ) ;

(* text-rendering *)
TextRenderingProp = auto | optimizeSpeed | optimizeLegibility | geometricPrecision ;

(* text-shadow *)
TextShadowProp = none | ShadowType , { comma_symbol , ShadowType } ;

(* text-size-adjust *)
TextSizeAdjustProp = auto | none | percentage_type ;

(* text-spacing-trim *)
TextSpacingTrimProp = SpacingTrimType | auto ;

(* text-transform *)
TextTransformProp = none | [ ( capitalize | uppercase | lowercase ) ] , [ full_width ] , [ full_size_kana ] | math_auto ;

(* text-underline-offset *)
TextUnderlineOffsetProp = auto | LengthPercentageType ;

(* text-underline-position *)
TextUnderlinePositionProp = auto | [ ( from_font | under ) ] , [ ( left | right ) ] ;

(* text-wrap-mode *)
TextWrapModeProp = wrap | nowrap ;

(* text-wrap-style *)
TextWrapStyleProp = auto | balance | stable | pretty | avoid_orphans ;

(* text-wrap *)
TextWrapProp = [ TextWrapModeProp ] , [ TextWrapStyleProp ] ;

(* timeline-scope *)
TimelineScopeProp = none | all | dashed_ident_type , { comma_symbol , dashed_ident_type } ;

(* top *)
TopProp = auto | LengthPercentageType | AnchorFn | AnchorSizeFn ;

(* touch-action *)
TouchActionProp = auto | none | ( [ ( pan_x | pan_left | pan_right ) ] , [ ( pan_y | pan_up | pan_down ) ] , [ pinch_zoom ] ) | manipulation ;

(* transform-box *)
TransformBoxProp = content_box | border_box | fill_box | stroke_box | view_box ;

(* transform-origin *)
TransformOriginProp = ( left | center | right | top | bottom | LengthPercentageType ) | ( left | center | right | LengthPercentageType ) , ( top | center | bottom | LengthPercentageType ) , [ length_type ] | ( ( center | left | right ) , ( center | top | bottom ) ) , [ length_type ] ;

(* transform-style *)
TransformStyleProp = flat | preserve_3d ;

(* transform *)
TransformProp = none | TransformListType ;

(* transition-behavior *)
TransitionBehaviorProp = TransitionBehaviorValueType , { comma_symbol , TransitionBehaviorValueType } ;

(* transition-delay *)
TransitionDelayProp = time_type , { comma_symbol , time_type } ;

(* transition-duration *)
TransitionDurationProp = time_type , { comma_symbol , time_type } ;

(* transition-Property *)
TransitionPropertyProp = none | SingleTransitionPropertyType , { comma_symbol , SingleTransitionPropertyType } ;

(* transition-timing-function *)
TransitionTimingFunctionProp = EasingFunctionType , { comma_symbol , EasingFunctionType } ;

(* transition *)
TransitionProp = SingleTransitionType , { comma_symbol , SingleTransitionType } ;

(* translate *)
TranslateProp = none | LengthPercentageType , [ LengthPercentageType , [ length_type ] ] ;

(* unicode-bidi *)
UnicodeBidiProp = normal | embed | isolate | bidi_override | isolate_override | plaintext ;

(* user-modify *)
UserModifyProp = read_only | read_write | read_write_plaintext_only | write_only ;

(* user-select *)
UserSelectProp = auto | text | none | contain | all ;

(* vector-effect *)
VectorEffectProp = none | non_scaling_stroke | non_scaling_size | non_rotation | fixed_position ;

(* vertical-align *)
VerticalAlignProp = [ ( first | last ) ] , [ AlignmentBaselineProp ] , [ BaselineShiftProp ] ;

(* view-timeline-axis *)
ViewTimelineAxisProp = ViewTimelineAxisPropItem , { comma_symbol , ViewTimelineAxisPropItem } ;
ViewTimelineAxisPropItem = ( block | inline | lowercase_x_symbol | lowercase_y_symbol ) ;

(* view-timeline-inset *)
ViewTimelineInsetProp = ViewTimelineInsetPropItem , { comma_symbol , ViewTimelineInsetPropItem } ;
ViewTimelineInsetPropItem2 = ( auto | LengthPercentageType ) ;
ViewTimelineInsetPropItem = ViewTimelineInsetPropItem2 , [ ViewTimelineInsetPropItem2 ] ;

(* view-timeline-name *)
ViewTimelineNameProp = ViewTimelineNamePropItem , { comma_symbol , ViewTimelineNamePropItem } ;
ViewTimelineNamePropItem = ( none | dashed_ident_type ) ;

(* view-timeline *)
ViewTimelineProp = ViewTimelinePropItem , { comma_symbol , ViewTimelinePropItem } ;
ViewTimelinePropItem = view_timeline_name , [ ( [ view_timeline_axis ] , [ view_timeline_inset ] ) ] ;

(* view-transition-class *)
ViewTransitionClassProp = none | custom_ident_type , { custom_ident_type } ;

(* view-transition-name *)
ViewTransitionNameProp = none | custom_ident_type ;

(* visibility *)
VisibilityProp = visible | hidden | force_hidden | collapse ;

(* white-space-collapse *)
WhiteSpaceCollapseProp = collapse | discard | preserve | preserve_breaks | preserve_spaces | break_spaces ;

(* white-space *)
WhiteSpaceProp = normal | pre | pre_wrap | pre_line | [ WhiteSpaceCollapseProp ] , [ TextWrapModeProp ] , [ white_space_trim ] ;

(* widows *)
WidowsProp = integer_type ;

(* width *)
WidthProp = auto | LengthPercentageType | min_content | max_content | FitContentFn | CalcSizeFn | AnchorSizeFn | stretch | fit_content | contain ;

(* will-change *)
WillChangeProp = auto | AnimateableFeatureType , { comma_symbol , AnimateableFeatureType } ;

(* word-break *)
WordBreakProp = normal | break_all | keep_all | manual | auto_phrase | break_word ;

(* word-spacing *)
WordSpacingProp = normal | LengthPercentageType ;

(* writing-mode *)
WritingModeProp = horizontal_tb | vertical_rl | vertical_lr | sideways_rl | sideways_lr ;

(* x *)
XProp = LengthPercentageType ;

(* y *)
YProp = LengthPercentageType ;

(* z-index *)
ZIndexProp = auto | integer_type | inherit ;

(* zoom *)
ZoomProp = number_type | percentage_type ;

(* grid-gap / grid-row-gap / grid-column-gap — deprecated gap shorthands *)
GridGapExpr    = grid_gap    , colon_symbol , ( GridGapProp    | AllProp ) , [ exclamation_mark_symbol , important ] , semicolon_symbol ;
GridRowGapExpr    = grid_row_gap    , colon_symbol , ( GridGapProp    | AllProp ) , [ exclamation_mark_symbol , important ] , semicolon_symbol ;
GridColumnGapExpr = grid_column_gap , colon_symbol , ( GridGapProp    | AllProp ) , [ exclamation_mark_symbol , important ] , semicolon_symbol ;
GridGapProp = ( LengthPercentageType | normal ) , [ LengthPercentageType | normal ] ;

(* Vendor-prefixed property — -vendor-name: <value> ; *)
VendorPropExpr = hyphen_symbol , ident_type , colon_symbol , VendorPropValue , [ exclamation_mark_symbol , important ] , semicolon_symbol ;
VendorPropValue = string_type | ColorType | LengthPercentageType | number_type | ident_type ;

