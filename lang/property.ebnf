ObjectPositionProp = PositionType ;

(* object-view-box *)
ObjectViewBoxProp = none | BasicShapeRectType ;

(* offset-anchor *)
OffsetAnchorProp = auto | PositionType ;

(* offset-distance *)
OffsetDistanceProp = LengthPercentageType ;

