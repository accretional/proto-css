PageBreakInsideProp = avoid | auto | inherit ;

(* page *)
PageProp = auto | custom_ident_type ;

(* paint-order *)
PaintOrderProp = normal | ( [ fill ] , [ stroke ] , [ markers ] ) ;

(* perspective-origin *)
PerspectiveOriginProp = PositionType ;

(* perspective *)
PerspectiveProp = none | length_type ;

(* place-content *)
PlaceContentProp = AlignContentProp , [ JustifyContentProp ] ;

(* place-items *)
PlaceItemsProp = AlignItemsProp , [ JustifyItemsProp ] ;

(* place-self *)
PlaceSelfProp = AlignSelfProp , [ JustifySelfProp ] ;

