ScrollSnapTypeProp = none | ( lowercase_x_symbol | lowercase_y_symbol | block | inline | both ) , [ ( mandatory | proximity ) ] ;

(* scroll-target-group *)
ScrollTargetGroupProp = none | auto ;

(* scroll-timeline-axis *)
ScrollTimelineAxisProp = ScrollTimelineAxisPropItem , { comma_symbol , ScrollTimelineAxisPropItem } ;
ScrollTimelineAxisPropItem = ( block | inline | lowercase_x_symbol | lowercase_y_symbol ) ;

(* scroll-timeline-name *)
ScrollTimelineNameProp = ScrollTimelineNamePropItem , { comma_symbol , ScrollTimelineNamePropItem } ;
ScrollTimelineNamePropItem = ( none | dashed_ident_type ) ;

(* scroll-timeline *)
ScrollTimelineProp = ScrollTimelinePropItem , { comma_symbol , ScrollTimelinePropItem } ;
ScrollTimelinePropItem = scroll_timeline_name , [ scroll_timeline_axis ] ;

(* scrollbar-color *)
ScrollbarColorProp = auto | ColorType , ColorType ;

(* scrollbar-gutter *)
ScrollbarGutterProp = auto | stable , [ both_edges ] ;

(* scrollbar-width *)
ScrollbarWidthProp = auto | thin | none ;

(* shape-image-threshold *)
ShapeImageThresholdProp = OpacityValueType ;

(* shape-margin *)
ShapeMarginProp = LengthPercentageType ;

(* shape-outside *)
ShapeOutsideProp = none | ( [ BasicShapeType ] , [ ShapeBoxType ] ) | ImageType ;

(* shape-rendering *)
ShapeRenderingProp = auto | optimizeSpeed | crispedges | geometricPrecision ;

(* speak-as *)
SpeakAsProp = normal | [ spell_out ] , [ digits ] , [ ( literal_punctuation | no_punctuation ) ] ;

(* stop-color *)
StopColorProp = ColorType ;

(* stop-opacity *)
StopOpacityProp = number_type | percentage_type ;

(* stroke-dasharray *)
StrokeDasharrayProp = none | StrokeDasharrayPropItem , { StrokeDasharrayPropItem } , (* skip: # *) ;
StrokeDasharrayPropItem = ( LengthPercentageType | number_type ) ;

(* stroke-dashoffset *)
StrokeDashoffsetProp = LengthPercentageType | number_type ;

(* stroke-linecap *)
StrokeLinecapProp = butt | round | square ;

(* stroke-linejoin *)
StrokeLinejoinProp = [ ( crop | arcs | miter ) ] , [ ( bevel | round | fallback ) ] ;

(* stroke-miterlimit *)
StrokeMiterlimitProp = number_type ;

