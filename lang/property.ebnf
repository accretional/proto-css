StrokeProp = PaintType ;

(* tab-size *)
TabSizeProp = number_type | length_type ;

(* table-layout *)
TableLayoutProp = auto | fixed ;

(* text-align-last *)
TextAlignLastProp = auto | start | end | left | right | center | justify | match_parent ;

(* text-align *)
TextAlignProp = start | end | left | right | center | string_type | justify | match_parent | justify_all ;

(* text-anchor *)
TextAnchorProp = start | middle | end ;

