PointerEventsProp = auto | bounding_box | visiblePainted | visibleFill | visibleStroke | visible | painted | fill | stroke | all | none ;

(* position-anchor *)
PositionAnchorProp = normal | none | auto | AnchorNameType | match_parent ;

(* position-area *)
PositionAreaProp = none | PositionAreaType ;

