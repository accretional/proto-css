(* symbol.ebnf — All printable ASCII characters in code point order.  *)
(* Quotation mark uses single-quote delimiter; reverse solidus is      *)
(* literal per ISO 14977 — no escape sequences in EBNF terminal strings. *)

space_symbol                = " " ;    (* 0x20 SPACE *)
exclamation_mark_symbol     = "!" ;    (* 0x21 EXCLAMATION MARK *)
quotation_mark_symbol       = '"' ;    (* 0x22 QUOTATION MARK — single quotes used as delimiter *)
number_sign_symbol          = "#" ;    (* 0x23 NUMBER SIGN *)
dollar_sign_symbol          = "$" ;    (* 0x24 DOLLAR SIGN *)
percent_sign_symbol         = "%" ;    (* 0x25 PERCENT SIGN *)
ampersand_symbol            = "&" ;    (* 0x26 AMPERSAND *)
apostrophe_symbol           = "'" ;    (* 0x27 APOSTROPHE *)
left_parenthesis_symbol     = "(" ;    (* 0x28 LEFT PARENTHESIS *)
right_parenthesis_symbol    = ")" ;    (* 0x29 RIGHT PARENTHESIS *)
asterisk_symbol             = "*" ;    (* 0x2A ASTERISK *)
plus_sign_symbol            = "+" ;    (* 0x2B PLUS SIGN *)
comma_symbol                = "," ;    (* 0x2C COMMA *)
hyphen_symbol               = "-" ;    (* 0x2D HYPHEN-MINUS *)
full_stop_symbol            = "." ;    (* 0x2E FULL STOP *)
solidus_symbol              = "/" ;    (* 0x2F SOLIDUS *)

digit_0_symbol              = "0" ;    (* 0x30 DIGIT ZERO *)
digit_1_symbol              = "1" ;    (* 0x31 DIGIT ONE *)
digit_2_symbol              = "2" ;    (* 0x32 DIGIT TWO *)
digit_3_symbol              = "3" ;    (* 0x33 DIGIT THREE *)
digit_4_symbol              = "4" ;    (* 0x34 DIGIT FOUR *)
digit_5_symbol              = "5" ;    (* 0x35 DIGIT FIVE *)
digit_6_symbol              = "6" ;    (* 0x36 DIGIT SIX *)
digit_7_symbol              = "7" ;    (* 0x37 DIGIT SEVEN *)
digit_8_symbol              = "8" ;    (* 0x38 DIGIT EIGHT *)
digit_9_symbol              = "9" ;    (* 0x39 DIGIT NINE *)

colon_symbol                = ":" ;    (* 0x3A COLON *)
semicolon_symbol            = ";" ;    (* 0x3B SEMICOLON *)
less_than_sign_symbol       = "<" ;    (* 0x3C LESS-THAN SIGN *)
equals_sign_symbol          = "=" ;    (* 0x3D EQUALS SIGN *)
greater_than_sign_symbol    = ">" ;    (* 0x3E GREATER-THAN SIGN *)
question_mark_symbol        = "?" ;    (* 0x3F QUESTION MARK *)
commercial_at_symbol        = "@" ;    (* 0x40 COMMERCIAL AT *)

uppercase_a_symbol          = "A" ;    (* 0x41 LATIN CAPITAL LETTER A *)
uppercase_b_symbol          = "B" ;    (* 0x42 LATIN CAPITAL LETTER B *)
uppercase_c_symbol          = "C" ;    (* 0x43 LATIN CAPITAL LETTER C *)
uppercase_d_symbol          = "D" ;    (* 0x44 LATIN CAPITAL LETTER D *)
uppercase_e_symbol          = "E" ;    (* 0x45 LATIN CAPITAL LETTER E *)
uppercase_f_symbol          = "F" ;    (* 0x46 LATIN CAPITAL LETTER F *)
uppercase_g_symbol          = "G" ;    (* 0x47 LATIN CAPITAL LETTER G *)
uppercase_h_symbol          = "H" ;    (* 0x48 LATIN CAPITAL LETTER H *)
uppercase_i_symbol          = "I" ;    (* 0x49 LATIN CAPITAL LETTER I *)
uppercase_j_symbol          = "J" ;    (* 0x4A LATIN CAPITAL LETTER J *)
uppercase_k_symbol          = "K" ;    (* 0x4B LATIN CAPITAL LETTER K *)
uppercase_l_symbol          = "L" ;    (* 0x4C LATIN CAPITAL LETTER L *)
uppercase_m_symbol          = "M" ;    (* 0x4D LATIN CAPITAL LETTER M *)
uppercase_n_symbol          = "N" ;    (* 0x4E LATIN CAPITAL LETTER N *)
uppercase_o_symbol          = "O" ;    (* 0x4F LATIN CAPITAL LETTER O *)
uppercase_p_symbol          = "P" ;    (* 0x50 LATIN CAPITAL LETTER P *)
uppercase_q_symbol          = "Q" ;    (* 0x51 LATIN CAPITAL LETTER Q *)
uppercase_r_symbol          = "R" ;    (* 0x52 LATIN CAPITAL LETTER R *)
uppercase_s_symbol          = "S" ;    (* 0x53 LATIN CAPITAL LETTER S *)
uppercase_t_symbol          = "T" ;    (* 0x54 LATIN CAPITAL LETTER T *)
uppercase_u_symbol          = "U" ;    (* 0x55 LATIN CAPITAL LETTER U *)
uppercase_v_symbol          = "V" ;    (* 0x56 LATIN CAPITAL LETTER V *)
uppercase_w_symbol          = "W" ;    (* 0x57 LATIN CAPITAL LETTER W *)
uppercase_x_symbol          = "X" ;    (* 0x58 LATIN CAPITAL LETTER X *)
uppercase_y_symbol          = "Y" ;    (* 0x59 LATIN CAPITAL LETTER Y *)
uppercase_z_symbol          = "Z" ;    (* 0x5A LATIN CAPITAL LETTER Z *)

left_square_bracket_symbol  = "[" ;    (* 0x5B LEFT SQUARE BRACKET *)
reverse_solidus_symbol      = "\" ;    (* 0x5C REVERSE SOLIDUS — literal backslash, no escape interpretation in EBNF *)
right_square_bracket_symbol = "]" ;    (* 0x5D RIGHT SQUARE BRACKET *)
circumflex_accent_symbol    = "^" ;    (* 0x5E CIRCUMFLEX ACCENT *)
low_line_symbol             = "_" ;    (* 0x5F LOW LINE *)
grave_accent_symbol         = "`" ;    (* 0x60 GRAVE ACCENT *)

lowercase_a_symbol          = "a" ;    (* 0x61 LATIN SMALL LETTER A *)
lowercase_b_symbol          = "b" ;    (* 0x62 LATIN SMALL LETTER B *)
lowercase_c_symbol          = "c" ;    (* 0x63 LATIN SMALL LETTER C *)
lowercase_d_symbol          = "d" ;    (* 0x64 LATIN SMALL LETTER D *)
lowercase_e_symbol          = "e" ;    (* 0x65 LATIN SMALL LETTER E *)
lowercase_f_symbol          = "f" ;    (* 0x66 LATIN SMALL LETTER F *)
lowercase_g_symbol          = "g" ;    (* 0x67 LATIN SMALL LETTER G *)
lowercase_h_symbol          = "h" ;    (* 0x68 LATIN SMALL LETTER H *)
lowercase_i_symbol          = "i" ;    (* 0x69 LATIN SMALL LETTER I *)
lowercase_j_symbol          = "j" ;    (* 0x6A LATIN SMALL LETTER J *)
lowercase_k_symbol          = "k" ;    (* 0x6B LATIN SMALL LETTER K *)
lowercase_l_symbol          = "l" ;    (* 0x6C LATIN SMALL LETTER L *)
lowercase_m_symbol          = "m" ;    (* 0x6D LATIN SMALL LETTER M *)
lowercase_n_symbol          = "n" ;    (* 0x6E LATIN SMALL LETTER N *)
lowercase_o_symbol          = "o" ;    (* 0x6F LATIN SMALL LETTER O *)
lowercase_p_symbol          = "p" ;    (* 0x70 LATIN SMALL LETTER P *)
lowercase_q_symbol          = "q" ;    (* 0x71 LATIN SMALL LETTER Q *)
lowercase_r_symbol          = "r" ;    (* 0x72 LATIN SMALL LETTER R *)
lowercase_s_symbol          = "s" ;    (* 0x73 LATIN SMALL LETTER S *)
lowercase_t_symbol          = "t" ;    (* 0x74 LATIN SMALL LETTER T *)
lowercase_u_symbol          = "u" ;    (* 0x75 LATIN SMALL LETTER U *)
lowercase_v_symbol          = "v" ;    (* 0x76 LATIN SMALL LETTER V *)
lowercase_w_symbol          = "w" ;    (* 0x77 LATIN SMALL LETTER W *)
lowercase_x_symbol          = "x" ;    (* 0x78 LATIN SMALL LETTER X *)
lowercase_y_symbol          = "y" ;    (* 0x79 LATIN SMALL LETTER Y *)
lowercase_z_symbol          = "z" ;    (* 0x7A LATIN SMALL LETTER Z *)

left_curly_bracket_symbol   = "{" ;    (* 0x7B LEFT CURLY BRACKET *)
vertical_line_symbol        = "|" ;    (* 0x7C VERTICAL LINE *)
right_curly_bracket_symbol  = "}" ;    (* 0x7D RIGHT CURLY BRACKET *)
tilde_symbol                = "~" ;    (* 0x7E TILDE *)

(* Multi-character sequences *)
double_hyphen_symbol        = "--" ;   (* CSS custom Property prefix *)
double_colon_symbol         = "::" ;   (* pseudo-element separator *)
double_vertical_line_symbol = "||" ;   (* column Combinator *)
